<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= programme.name %> Students | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container">
      <a class="navbar-brand" href="/academic/dashboard">HEdClass</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link">Logged in as <%= user.first_name %> <%= user.last_name %></span>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1><%= programme.name %></h1>
        <p class="text-muted mb-0">Programme Code: <%= programme.programme_code %></p>
      </div>
      <div class="d-flex gap-2">
        <a href="/academic/addStudent" class="btn btn-success">+ Add Student</a>
        <a href="/academic/programmeDashboard/<%= programme.id %>" class="btn btn-secondary">Back to Programme</a>
      </div>
    </div>

    <%# Active Students %>
    <h4>Active Students (<%= activeStudents.length %>)</h4>
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Student Number</th>
          <th>Name</th>
          <th>Enrolled Date</th>
          <th>Graduation Year</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (activeStudents.length > 0) { %>
          <% activeStudents.forEach(student => { %>
            <tr>
              <td><%= student.student_number %></td>
              <td><%= student.first_name %> <%= student.last_name %></td>
              <td><%= student.enrolled_date %></td>
              <td><%= student.graduation_year %></td>
              <td>
                <a href="/academic/studentProfile/<%= student.id %>">
                  <button type="button" class="btn btn-info btn-sm">View</button>
                </a>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5">No active students on this programme.</td>
          </tr>
        <% } %>
      </tbody>
    </table>

    <%# Inactive Students %>
    <h4 class="mt-4">Inactive Students (<%= inactiveStudents.length %>)</h4>
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Student Number</th>
          <th>Name</th>
          <th>Enrolled Date</th>
          <th>Graduation Year</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (inactiveStudents.length > 0) { %>
          <% inactiveStudents.forEach(student => { %>
            <tr class="text-muted">
              <td><%= student.student_number %></td>
              <td><%= student.first_name %> <%= student.last_name %></td>
              <td><%= student.enrolled_date %></td>
              <td><%= student.graduation_year %></td>
              <td>
                <a href="/academic/studentProfile/<%= student.id %>">
                  <button type="button" class="btn btn-outline-secondary btn-sm">View</button>
                </a>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5">No inactive students on this programme.</td>
          </tr>
        <% } %>
      </tbody>
    </table>

  </div>

</body>
</html>