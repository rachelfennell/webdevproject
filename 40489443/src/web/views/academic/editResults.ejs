<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Results | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container">
      <a class="navbar-brand" href="/academic/dashboard">HEdClass</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link">Logged in as <%= user.first_name %> <%= user.last_name %></span>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1>Edit Results</h1>
        <p class="text-muted mb-0">
          <%= student.first_name %> <%= student.last_name %>
          (<%= student.student_number %>) —
          <%= student.Programme.name %>
        </p>
      </div>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <% if (programmeModules.length === 0) { %>
      <div class="alert alert-info">No modules assigned to this programme.</div>
    <% } else { %>
      <% programmeModules.forEach(pm => { %>
        <%
          const original = results.find(r => r.module_id === pm.module_id && r.is_resit === false);
          const resit = results.find(r => r.module_id === pm.module_id && r.is_resit === true);
        %>
        <div class="card mb-3">
          <div class="card-header bg-white">
            <h6 class="mb-0">
              <%= pm.Module.name %> —
              <%= pm.Module.module_code %>
              (Year <%= pm.year_level %> | <%= pm.credits %> credits)
            </h6>
          </div>
          <div class="card-body">
<form action="/academic/editResults/<%= student.id %>?from=<%= from %>" method="POST">
  <input type="hidden" name="module_id" value="<%= pm.module_id %>" />
  <input type="hidden" name="year_level" value="<%= pm.year_level %>" />

              <div class="row">
                <div class="col-md-5 mb-3">
                  <label class="form-label">Original Mark</label>
                  <input
                    type="number"
                    class="form-control"
                    name="original_mark"
                    value="<%= original ? original.mark : '' %>"
                    min="0"
                    max="100"
                    step="0.01"
                    placeholder="—" />
                </div>
                <div class="col-md-5 mb-3">
                  <label class="form-label">Resit Mark <span class="text-muted">(leave blank if none)</span></label>
                  <input
                    type="number"
                    class="form-control"
                    name="resit_mark"
                    value="<%= resit ? resit.mark : '' %>"
                    min="0"
                    max="100"
                    step="0.01"
                    placeholder="—" />
                </div>
                <div class="col-md-2 mb-3 d-flex align-items-end">
                  <button type="submit" class="btn btn-primary w-100">Save</button>
                </div>
              </div>

            </form>
          </div>
        </div>
      <% }) %>
    <% } %>

    <div class="mt-2">
<a href="<%= from %>" class="btn btn-secondary">
  Back
</a>
    </div>

  </div>

</body>
</html>