<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Results Page</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
    <%# Top row %>
      <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
        <a class="navbar-brand mb-0" href="/academic/dashboard">
          <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
        </a>
        <span class="text-white">Logged in as <%= user.first_name %>
            <%= user.last_name %></span>
      </div>

      <%# Bottom row %>
        <div class="w-100 py-2 d-flex justify-content-end">
          <ul class="navbar-nav flex-row gap-3">
            <li class="nav-item">
              <a class="nav-link" href="/academic/dashboard">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/academic/studentList">Students List</a>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                Assigned Programmes
              </a>
              <ul class="dropdown-menu">
                <% if (userProgrammes && userProgrammes.length> 0) { %>
                  <% userProgrammes.forEach(userProgramme=> { %>
                    <li>
                      <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
                        <%= userProgramme.Programme.name .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>

 <div class="container mt-5">


<div class="card shadow-sm p-3 mb-4">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h4 class="mb-0"><%= student.first_name %> <%= student.last_name %></h4>
        <p class="text-muted mb-0">
          <%= student.Programme.name.split(' ')
            .map(word => word.charAt(0).toUpperCase() + word.slice(1))
            .join(' ') %>
        </p>
      </div>
      <div class="text-end">
        <p class="mb-0"><strong>Student Number: </strong> <%= student.student_number %></p>
      </div>
    </div>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger text-center">
      <%= error %>
    </div>
  <% } %>

     


                            <% if (programmeModules.length===0) { %>

                              <div class="alert alert-info">
                                No modules assigned to this programme.
                              </div>

                              <% } else { %>



                                <% programmeModules.forEach(pm=> { %>

                                  <% const original=results.find( r=> r.module_id === pm.module_id && r.is_resit ===
                                    false
                                    );

                                    const resit = results.find(
                                    r => r.module_id === pm.module_id && r.is_resit === true
                                    );
                                    %>


                                    <div class="card shadow-sm mb-4">



                                      <div class="card-header bg-white">
                                        <h5 class="mb-0">
                                          <%= pm.Module.name %> —
                                            <%= pm.Module.module_code %>
                                        </h5>

                                        <small class="text-muted">
                                          Year <%= pm.year_level %> • <%= pm.credits %> credits
                                        </small>
                                      </div>

                                      <div class="card-body">


                                        <form action="/academic/editResults/<%= student.id %>?from=<%= from %>"
                                          method="POST">

                                          <input type="hidden" name="module_id" value="<%= pm.module_id %>">
                                          <input type="hidden" name="year_level" value="<%= pm.year_level %>">


                                          <div class="row">

                                            <div class="col-md-5 mb-3">
                                              <label class="form-label">Original Mark</label>
                                              <input type="number" class="form-control" name="original_mark"
                                                value="<%= original ? original.mark : '' %>" min="0" max="100"
                                                step="0.01" placeholder="—">
                                            </div>


                                            <div class="col-md-5 mb-3">
                                              <label class="form-label">
                                                Resit Mark <span class="text-muted">(Optional)</span>
                                              </label>
                                              <input type="number" class="form-control" name="resit_mark"
                                                value="<%= resit ? resit.mark : '' %>" min="0" max="100" step="0.01"
                                                placeholder="—">
                                            </div>


                                            <div class="col-md-2 mb-3 d-flex align-items-end">
                                              <button type="submit" class="btn dashboardButton">
                                                Save
                                              </button>
                                            </div>

                                          </div>

                                        </form>

                                      </div>
                                    </div>

                                    <% }) %>

                                      <% } %>

        
 </div>

        <div class="container mt-5 mb-5">
          <div class="d-flex justify-content-end">
            <a href="<%= from %>" class="btn dashboardButton">
              Back to Student
            </a>
          </div>
        </div>

        <div class="pageSpacing"></div>

</body>

</html>