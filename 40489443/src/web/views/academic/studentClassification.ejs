<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academic Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body><nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
 <%# Top row %>
    <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
      <a class="navbar-brand mb-0" href="/academic/dashboard">
        <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
      </a>
      <span class="text-white">Logged in as <%= user.first_name %> <%= user.last_name %></span>
    </div>

  <%# Bottom row %>
  <div class="w-100 py-2 d-flex justify-content-end">
      <ul class="navbar-nav flex-row gap-3">
        <li class="nav-item">
        <a class="nav-link" href="/academic/dashboard">Home</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/studentList">Students List</a>
      </li>
<li class="nav-item dropdown">
  <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
    Assigned Programmes
  </a>
  <ul class="dropdown-menu">
  <% if (userProgrammes && userProgrammes.length > 0) { %>
    <% userProgrammes.forEach(userProgramme => { %>
      <li>
        <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
          <%= userProgramme.Programme.name  .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>

  <div class="container mt-5">

  <div class="row g-4">

    
    <div class="col-12 col-lg-4">

      <div class="card shadow-sm p-3">

        <div class="d-flex justify-content-between align-items-center">
          <h4 class="mb-0">
            <%= student.first_name %> <%= student.last_name %>
          </h4>


        </div>

        <hr>

        <p><strong>Student Number:</strong> <%= student.student_number %></p>

        <p><strong>Programme:</strong>
          <%= student.Programme.name.split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
          %>
          (<%= student.Programme.programme_code %>)
        </p>

        <p><strong>Degree Type:</strong> <%= student.Programme.degree_type %></p>

        <p><strong>School:</strong> <%= student.Programme.school %></p>

        <p><strong>Graduation Year:</strong> <%= student.graduation_year %></p>

      </div>


<div class="container mt-5 mb-5">
 
      <div class="d-flex justify-content-end">
          <a href="/academic/studentProfile/<%= student.id %>" class="btn dashboardButton">
            Back to Student Profile
          </a>
        
  </div>
</div>

    </div>

    <!-- RIGHT -->
    <div class="col-12 col-lg-8">

     
      <div class="card shadow-sm mb-4">

        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Run Classification</h5>
        </div>

        <div class="card-body">
          <p class="text-muted">
            Run the classification engine using current results.
          </p>

          <form action="/academic/studentClassification/<%= student.id %>" method="POST">
            <button type="submit"
              class="btn btn-primary"
              onclick="return confirm('Run classification for this student?')">
              Run Classification
            </button>
          </form>
        </div>

      </div>

      <% if (classification) { %>

   
      <div class="card shadow-sm mb-4">

        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Classification Result</h5>

          <% if (classification.is_overridden) { %>
            <span class="badge bg-warning text-dark">Overridden</span>
          <% } else { %>
            <span class="badge bg-success">System Generated</span>
          <% } %>
        </div>

        <div class="card-body">

          <div class="row mb-3">

            <div class="col-md-3">
              <p class="text-muted mb-1">Year 2</p>
              <p><%= classification.y2_average ?? '—' %>%</p>
            </div>

            <div class="col-md-3">
              <p class="text-muted mb-1">Year 3</p>
              <p><%= classification.y3_average ?? '—' %>%</p>
            </div>

            <div class="col-md-3">
              <p class="text-muted mb-1">Final</p>
              <p><%= classification.final_average ?? '—' %>%</p>
            </div>

            <div class="col-md-3">
              <p class="text-muted mb-1">Proposed</p>
              <p><strong><%= classification.proposed_outcome %></strong></p>
            </div>

          </div>

          <div class="row">

            <div class="col-md-6">
              <p class="text-muted mb-1">Final Outcome</p>
              <p><strong><%= classification.final_outcome %></strong></p>
            </div>

            <div class="col-md-6">
              <p class="text-muted mb-1">Date</p>
              <p>
                <%= classification.classified_at
                  ? new Date(classification.classified_at).toLocaleDateString('en-GB')
                  : '—' %>
              </p>
            </div>

          </div>

          <% if (classification.rationale) { %>
            <hr>
            <p class="text-muted mb-1">Rationale</p>
            <p><%= classification.rationale %></p>
          <% } %>

        </div>

      </div>

  
      <div class="card shadow-sm mb-4">

        <div class="card-header bg-white">
          <h5 class="mb-0">Override Classification</h5>
        </div>

        <div class="card-body">

          <form action="/academic/classificationOverride/<%= student.id %>" method="POST">

            <div class="mb-3">
              <label class="form-label">Final Outcome</label>

              <select name="final_outcome" class="form-control" required>
                <option value="">Select</option>
                <option>First Class Honours</option>
                <option>Upper Second Class (2:1)</option>
                <option>Lower Second Class (2:2)</option>
                <option>Third Class Honours</option>
                <option>Fail</option>
                <option>Not Eligible</option>
              </select>

            </div>

            <div class="mb-3">
              <label class="form-label">Rationale</label>
              <textarea name="rationale" class="form-control" rows="4" required></textarea>
            </div>

            <button type="submit"
              class="btn btn-warning"
              onclick="return confirm('Override classification?')">
              Override
            </button>

          </form>

        </div>

      </div>

      
      <div class="card shadow-sm">

        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Flag Student</h5>

          <% if (classification.is_flagged) { %>
            <span class="badge bg-danger">Flagged</span>
          <% } %>
        </div>

        <div class="card-body">

          <form action="/academic/flagStudent/<%= student.id %>" method="POST">

            <div class="form-check mb-3">
              <input type="checkbox"
                     class="form-check-input"
                     name="is_flagged"
                     <%= classification.is_flagged ? 'checked' : '' %>>
              <label class="form-check-label">Flag for review</label>
            </div>

            <div class="mb-3">
              <label class="form-label">Reason</label>
              <textarea name="flag_reason" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit"
              class="btn btn-warning"
              onclick="return confirm('Update flag status?')">
              Save
            </button>

          </form>

        </div>

      </div>

      <% } else { %>

        <div class="alert alert-info">
          No classification available. Run classification to begin.
        </div>

      <% } %>

    </div>

  </div>
</div>

<div class="container mt-5 mb-5">
  <div class="d-flex justify-content-end">
     

<button onclick="history.back()" class="btn dashboardButton">
              Back to Programme Dashboard
            </button>


          </div>
          </div>


        



<div class="pageSpacing"></div>
</body>
</html>

</body>
</html>