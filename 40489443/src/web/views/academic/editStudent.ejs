<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academic Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body><nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
 <%# Top row %>
    <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
      <a class="navbar-brand mb-0" href="/academic/dashboard">
        <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
      </a>
      <span class="text-white">Logged in as <%= user.first_name %> <%= user.last_name %></span>
    </div>

  <%# Bottom row %>
  <div class="w-100 py-2 d-flex justify-content-end">
      <ul class="navbar-nav flex-row gap-3">
        <li class="nav-item">
        <a class="nav-link" href="/academic/dashboard">Home</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/studentList">Students List</a>
      </li>
<li class="nav-item dropdown">
  <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
    Assigned Programmes
  </a>
  <ul class="dropdown-menu">
  <% if (userProgrammes && userProgrammes.length > 0) { %>
    <% userProgrammes.forEach(userProgramme => { %>
      <li>
        <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
          <%= userProgramme.Programme.name  .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>

  <div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1>Edit Student</h1>
      <p class="text-muted mb-0">
        <%= student.first_name %> <%= student.last_name %>
        (<%= student.student_number %>)
      </p>
    </div>

 
  </div>

 
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger">
      <%= error %>
    </div>
  <% } %>

  <div class="card shadow-sm">

    <div class="card-header bg-white">
      <h5 class="mb-0">Student Details</h5>
    </div>

    <div class="card-body">

      <form action="/academic/editStudent/<%= student.id %>" method="POST">

        <div class="row g-3">

          
          <div class="col-md-6">
            <label class="form-label">Student Number</label>
            <input
              type="text"
              class="form-control"
              name="student_number"
              value="<%= student.student_number %>"
              required />
          </div>

          
          <div class="col-md-6">
            <label class="form-label">First Name</label>
            <input
              type="text"
              class="form-control"
              name="first_name"
              value="<%= student.first_name %>"
              required />
          </div>

         
          <div class="col-md-6">
            <label class="form-label">Last Name</label>
            <input
              type="text"
              class="form-control"
              name="last_name"
              value="<%= student.last_name %>"
              required />
          </div>

          
          <div class="col-md-6">
            <label class="form-label">Date of Birth</label>
            <input
              type="date"
              class="form-control"
              name="dob"
              value="<%= student.dob %>"
              required />
          </div>

          
          <div class="col-md-12">
            <label class="form-label">Programme</label>
            <select class="form-control" name="programme_id" required>

              <option value="">Select Programme</option>

              <% programmes.forEach(userProgramme => { %>
                <option
                  value="<%= userProgramme.Programme.id %>"
                  <%= student.programme_id === userProgramme.Programme.id ? 'selected' : '' %>>
                  <%= userProgramme.Programme.name.split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ') %> - <%= userProgramme.Programme.programme_code %>
                </option>
              <% }) %>

            </select>
          </div>

         
          <div class="col-md-6">
            <label class="form-label">Enrolled Date</label>
            <input
              type="date"
              class="form-control"
              name="enrolled_date"
              value="<%= student.enrolled_date %>"
              required />
          </div>

         
          <div class="col-md-6">
            <label class="form-label">Graduation Year</label>
            <input
              type="number"
              class="form-control"
              name="graduation_year"
              value="<%= student.graduation_year %>"
              min="1990"
              max="2100"
              required />
          </div>

          

        </div>

        
        <div class="d-flex gap-2 mt-4">

          <button type="submit" class="btn dashboardButton">
            Save Changes
          </button>

          <a href="/academic/studentProfile/<%= student.id %>" class="btn btn-secondary">
            Cancel
          </a>

        </div>

      </form>

    </div>
  </div>

  
  <div class="card shadow-sm mt-4">

    <div class="card-header bg-white">
      <h5 class="mb-0 ">Deactivate Student</h5>
    </div>

    <div class="card-body">

      <form action="/academic/deactivateStudent/<%= student.id %>" method="POST">

        <p class="text-muted">
          Deactivating a student will remove them from active lists but keep their data.
        </p>

        <button
          type="submit"
          class="btn btn-danger"
          onclick="return confirm('Are you sure you want to deactivate this student?')">

          Deactivate Student

        </button>

      </form>

    </div>
  </div>

</div>
<div class="container mt-5 mb-5">
  <div class="d-flex justify-content-end">
      <a href="/academic/studentProfile/<%= student.id %>"
             class="btn btn-sm dashboardButton">
            Back to Student Profile
          </a>

          </div>
          </div>
<div class="pageSpacing"></div>

</body>
</html>