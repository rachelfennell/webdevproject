<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academic Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
   <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body><nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
 <%# Top row %>
    <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
      <a class="navbar-brand mb-0" href="/academic/dashboard">
        <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
      </a>
      <span class="text-white">Logged in as <%= user.first_name %> <%= user.last_name %></span>
    </div>

  <%# Bottom row %>
  <div class="w-100 py-2 d-flex justify-content-end">
      <ul class="navbar-nav flex-row gap-3">
        <li class="nav-item">
        <a class="nav-link" href="/academic/dashboard">Home</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/studentList">Students List</a>
      </li>
<li class="nav-item dropdown">
  <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
    Assigned Programmes
  </a>
  <ul class="dropdown-menu">
  <% if (userProgrammes && userProgrammes.length > 0) { %>
    <% userProgrammes.forEach(userProgramme => { %>
      <li>
        <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
          <%= userProgramme.Programme.name  .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>

<div class="container mt-5">
    <div class="row g-4">

      <%# Left Column — Student Details %>
      <div class="col-12 col-lg-6">
        <div class="card p-3">

          <div class="d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Edit Student</h4>
          </div>

          <hr>


 
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger">
      <%= error %>
    </div>
  <% } %>

 



 <form action="/academic/editStudent/<%= student.id %>" method="POST">
       
          
          <div class="form-group mb-3">
            <label class="form-label">Student Number</label>
            <input
              type="text"
              class="form-control"
              name="student_number"
              value="<%= student.student_number %>"
               maxlength="10"
              required />
               <div class="form-text">Must be exactly 10 digits</div>
          </div>

          
          <div class="form-group mb-3">
            <label class="form-label">First Name</label>
            <input
              type="text"
              class="form-control"
              name="first_name"
              value="<%= student.first_name %>"
              required />
          </div>

         
          <div class="form-group mb-3">
            <label class="form-label">Last Name</label>
            <input
              type="text"
              class="form-control"
              name="last_name"
              value="<%= student.last_name %>"
              required />
          </div>

          
          <div class="form-group mb-3">
            <label class="form-label">Date of Birth</label>
            <input
              type="date"
              class="form-control"
              name="dob"
              value="<%= student.dob %>"
              required />
              
          </div>

          
          <div class="form-group mb-3">
            <label class="form-label">Programme</label>
            <select class="form-control" name="programme_id" required>

              <option value="">Select Programme</option>

              <% programmes.forEach(userProgramme => { %>
                <option
                  value="<%= userProgramme.Programme.id %>"
                  <%= student.programme_id === userProgramme.Programme.id ? 'selected' : '' %>>
                  <%= userProgramme.Programme.name.split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ') %> - <%= userProgramme.Programme.programme_code %>
                </option>
              <% }) %>

            </select>
          </div>

         
          <div class="form-group mb-3">
            <label class="form-label">Enrolled Date</label>
            <input
              type="date"
              class="form-control"
              name="enrolled_date"
              value="<%= student.enrolled_date ? new Date(student.enrolled_date).toISOString().split('T')[0] : '' %>"
              required />
          </div>

         
          <div class="form-group mb-3">
            <label class="form-label">Graduation Year</label>
            <input
              type="number"
              class="form-control"
              name="graduation_year"
              value="<%= student.graduation_year %>"
              min="1990"
              max="2100"
              required />
          </div>

          

    
        
        <div class="d-flex gap-2 mt-4">

          <button type="submit" class="btn dashboardButton">
            Save Changes
          </button>

          <a href="/academic/studentProfile/<%= student.id %>" class="btn btn-secondary">
            Cancel
          </a>

        </div>

      </form>

   
  </div>
</div>

  <%# Right Side %>
  
  <div class="col-12 col-lg-6">
    <% if (student.active_student) { %>
 <div class="card shadow-sm p-3 border-danger">

          <div class="d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Deactivate Student</h4>
          </div>

          <hr>



      <form action="/academic/deactivateStudent/<%= student.id %>" method="POST">

        <p class="text-muted">
          Deactivating a student will remove them from active lists but keep their data.
          This action can be reversed by editing the student record.
        </p>

        <button
          type="submit"
          class="btn btn-danger"
          onclick="return confirm('Are you sure you want to deactivate this student?')">

          Deactivate Student

        </button>

      </form>
       </div>
<% } %>

   



  <% if (!student.active_student) { %>
 <div class="card shadow-sm p-3 border-danger">

          <div class="d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Reactivate Student</h4>
          </div>

          <hr>



  
  <form action="/academic/reactivateStudent/<%= student.id %>" method="POST">

 <p class="text-muted">
          Click this button to reactivate this student.
        </p>

    <button type="submit" class="btn btn-success"
      onclick="return confirm('Are you sure you want to reactivate this student?')">
      Reactivate Student
    </button>
  </form>

</div>
<% } %>
   
  



 </div>



  







<div class="container mt-5 mb-5">
  <div class="d-flex justify-content-end">
      <a href="/academic/studentProfile/<%= student.id %>"
             class="btn btn-sm dashboardButton">
            Back to Student Profile
          </a>

          </div>
          </div>
        
          
<div class="pageSpacing"></div>

</body>
</html>