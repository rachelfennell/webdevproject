<h3>Edit Student</h3>
<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<form method="POST" action="/academic/students/edit/<%= student.id %>">
  <input type="text" name="first_name" value="<%= student.first_name %>" class="form-control mb-2" required>
  <input type="text" name="last_name" value="<%= student.last_name %>" class="form-control mb-2" required>
  <input type="text" name="student_number" value="<%= student.student_number %>" class="form-control mb-2" required>

  <label>Programme</label>
  <select name="programmeId" class="form-select mb-2" required>
    <% programmes.forEach(programme => { %>
      <option value="<%= programme.id %>" <%= programme.id === student.programmeId ? 'selected' : '' %>>
        <%= programme.name %>
      </option>
    <% }) %>
  </select>

  <button class="btn btn-primary">Update Student</button>
</form>