<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Student Page</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body><nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
 <%# Top row %>
    <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
      <a class="navbar-brand mb-0" href="/academic/dashboard">
        <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
      </a>
      <span class="text-white">Logged in as <%= user.first_name %> <%= user.last_name %></span>
    </div>

  <%# Bottom row %>
  <div class="w-100 py-2 d-flex justify-content-end">
      <ul class="navbar-nav flex-row gap-3">
        <li class="nav-item">
        <a class="nav-link" href="/academic/dashboard">Home</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/studentList">Students List</a>
      </li>
<li class="nav-item dropdown">
  <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
    Assigned Programmes
  </a>
  <ul class="dropdown-menu">
  <% if (userProgrammes && userProgrammes.length > 0) { %>
    <% userProgrammes.forEach(userProgramme => { %>
      <li>
        <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
          <%= userProgramme.Programme.name  .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>
 <div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1>Create a New Student</h1>
        
      </div>
      
    </div>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="card">
      <div class="card-body">
        <form action="/academic/addStudent" method="POST">

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="student_number" class="form-label">Student Number</label>
              <input
                type="text"
                class="form-control"
                id="student_number"
                name="student_number"
                required
                maxlength="10"
                placeholder="10 digit number" />
              <div class="form-text">Must be exactly 10 digits, numbers only.</div>
            </div>
            <div class="col-md-6 mb-3">
              <label for="programme_id" class="form-label">Programme</label>
              <select class="form-control" id="programme_id" name="programme_id" required>
                <option value="">Select a programme</option>
                <% programmes.forEach(up => { %>
                  <option value="<%= up.Programme.id %>">
                    <%= up.Programme.name %> — <%= up.Programme.programme_code %>
                  </option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="first_name" class="form-label">First Name</label>
              <input
                type="text"
                class="form-control"
                id="first_name"
                name="first_name"
                required />
            </div>
            <div class="col-md-6 mb-3">
              <label for="last_name" class="form-label">Last Name</label>
              <input
                type="text"
                class="form-control"
                id="last_name"
                name="last_name"
                required />
            </div>
          </div>

          <div class="row">
            <div class="col-md-4 mb-3">
              <label for="dob" class="form-label">Date of Birth</label>
              <input
                type="date"
                class="form-control"
                id="dob"
                name="dob"
                required />
              <div class="form-text">Student must be between 16 and 100 years old.</div>
            </div>
            <div class="col-md-4 mb-3">
              <label for="enrolled_date" class="form-label">Enrolled Date</label>
              <input
                type="date"
                class="form-control"
                id="enrolled_date"
                name="enrolled_date"
                required />
            </div>
            <div class="col-md-4 mb-3">
              <label for="graduation_year" class="form-label">Graduation Year</label>
              <input
                type="number"
                class="form-control"
                id="graduation_year"
                name="graduation_year"
                min="1990"
                max="2100"
                required />
            </div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label"></label>
              <div class="form-check mt-1">
                <input
                  type="checkbox"
                  class="form-check-input"
                  id="active_student"
                  name="active_student"
                  value="on"
                  checked />
                <label class="form-check-label" for="active_student">
                  Mark as active
                </label>
              </div>
            </div>
          </div>

          <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn dashboardButton">Add Student</button>
            <a href="/academic/studentList" class="btn btn-secondary">Cancel</a>
          </div>

        </form>
      </div>
    </div>

  </div>

<div class="container mt-5 mb-5">
  <div class="d-flex justify-content-end">
   <a href="/academic/studentList" class="btn dashboardButton">Back to Student List</a>

  </div>
</div>





  <div class="pageSpacing"></div>

</body>
</html>