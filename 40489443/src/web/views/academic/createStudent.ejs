<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Student Page</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
    <%# Top row %>
      <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
        <a class="navbar-brand mb-0" href="/academic/dashboard">
          <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
        </a>
        <span class="text-white">Logged in as <%= user.first_name %>
            <%= user.last_name %></span>
      </div>

      <%# Bottom row %>
        <div class="w-100 py-2 d-flex justify-content-end">
          <ul class="navbar-nav flex-row gap-3">
            <li class="nav-item">
              <a class="nav-link" href="/academic/dashboard">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/academic/studentList">Students List</a>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                Assigned Programmes
              </a>
              <ul class="dropdown-menu">
                <% if (userProgrammes && userProgrammes.length> 0) { %>
                  <% userProgrammes.forEach(userProgramme=> { %>
                    <li>
                      <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
                        <%= userProgramme.Programme.name .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>

<div class="container mt-5">
  <div class="row justify-content-center">

    <div class="col-12 col-lg-8">

      <div class="card shadow-sm p-4">

        <h4 class="mb-3">Create a New Student</h4>

        <% if (error) { %>
          <div class="alert alert-danger text-center shadow-sm">
            <%= error %>
          </div>
        <% } %>

        <% if (message) { %>
          <div class="alert alert-warning text-center shadow-sm">
            <%= message %>
          </div>
        <% } %>

        <form action="/academic/createStudent" method="POST">

          <div class="mb-3">
            <label class="form-label">Student Number</label>
            <input type="text" name="student_number" class="form-control" maxlength="10" placeholder="10 digit number" required>
            <div class="form-text">Must be exactly 10 digits, numbers only.</div>
          </div>

          <div class="mb-3">
            <label class="form-label">Programme</label>
            <select name="programme_id" class="form-control" required>
              <option value="">Select a programme</option>
              <% programmes.forEach(up => { %>
                <option value="<%= up.Programme.id %>">
                  <%= up.Programme.name.split(' ')
                    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
                    .join(' ') %> — <%= up.Programme.programme_code %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">First Name</label>
            <input type="text" name="first_name" class="form-control" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Last Name</label>
            <input type="text" name="last_name" class="form-control" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Date of Birth</label>
            <input type="date" name="dob" class="form-control" required>
            <div class="form-text">Student must be between 16 and 100 years old.</div>
          </div>

          <div class="mb-3">
            <label class="form-label">Enrolled Date</label>
            <input type="date" name="enrolled_date" class="form-control" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Graduation Year</label>
            <input type="number" name="graduation_year" class="form-control" min="1990" max="2100" required>
          </div>

          <div class="mb-3">
            <div class="form-check">
              <input type="checkbox" class="form-check-input" id="active_student" name="active_student" value="on" checked>
              <label class="form-check-label" for="active_student">Mark as active</label>
            </div>
          </div>

          <div class="d-flex justify-content-between mt-4">
            <a href="/academic/studentList" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn dashboardButton">Add Student</button>
          </div>

        </form>

      </div>
    </div>

  </div>
</div>

<div class="pageSpacing"></div>

</body>
</html>