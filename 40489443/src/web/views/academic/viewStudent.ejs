<h3>Students</h3>
<a href="/academic/students/add" class="btn btn-success mb-3">Add Student</a>

<table class="table table-bordered">
  <thead>
    <tr>
      <th>Student Number</th>
      <th>Name</th>
      <th>Programme</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% students.forEach(student => { %>
      <tr>
        <td><%= student.student_number %></td>
        <td><%= student.first_name %> <%= student.last_name %></td>
        <td><%= student.Programme?.name || 'N/A' %></td>
        <td>
          <a href="/academic/students/edit/<%= student.id %>" class="btn btn-sm btn-primary">Edit</a>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>