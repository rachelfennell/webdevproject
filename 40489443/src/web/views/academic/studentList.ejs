<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academic Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body><nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
 <%# Top row %>
    <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
      <a class="navbar-brand mb-0" href="/academic/dashboard">
        <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
      </a>
      <span class="text-white">Logged in as <%= user.first_name %> <%= user.last_name %></span>
    </div>

  <%# Bottom row %>
  <div class="w-100 py-2 d-flex justify-content-end">
      <ul class="navbar-nav flex-row gap-3">
        <li class="nav-item">
        <a class="nav-link" href="/academic/dashboard">Home</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/studentList">Students List</a>
      </li>
<li class="nav-item dropdown">
  <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
    Assigned Programmes
  </a>
  <ul class="dropdown-menu">
  <% if (userProgrammes && userProgrammes.length > 0) { %>
    <% userProgrammes.forEach(userProgramme => { %>
      <li>
        <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
          <%= userProgramme.Programme.name  .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>



  <div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Queens University - All Students</h2>
  </div>

  <% if (message) { %>
    <div class="alert alert-info">
      <%= message %>
    </div>
  <% } %>

  <div class="row g-4">


  
    <div class="col-12">

      <div class="card shadow-sm">

        <div class="card-header bg-white">
          <h5 class="mb-0">Your Students</h5>
        </div>

        <div class="card-body table-responsive">

          <% if (assignedStudents.length > 0) { %>

            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Student Number</th>
                  <th>Name</th>
                  <th>Programme</th>
                  <th>Graduation Year</th>
                  <th>Action</th>
                </tr>
              </thead>

              <tbody>
                <% assignedStudents.forEach(student => { %>
                  <tr>
                    <td><%= student.student_number %></td>
                    <td><%= student.first_name %> <%= student.last_name %></td>
                    <td><%= student.Programme.name .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
                      %></td>
                    <td><%= student.graduation_year %></td>
                    <td>
                      <a href="/academic/studentProfile/<%= student.id %>"
                         class="btn dashboardButton btn-sm">
                        View
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>

          <% } else { %>
            <p class="text-muted mb-0">
              No students assigned to your programmes.
            </p>
          <% } %>

        </div>
      </div>
    </div>


   
    <div class="col-12">

      <div class="card shadow-sm">

        <div class="card-header bg-white">
          <h5 class="mb-0">Other Students</h5>
        </div>

        <div class="card-body table-responsive">

          <% if (unassignedStudents.length > 0) { %>

            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Student Number</th>
                  <th>Name</th>
                  <th>Programme</th>
                  <th>Graduation Year</th>
                  <th>Access</th>
                </tr>
              </thead>

              <tbody>
                <% unassignedStudents.forEach(student => { %>
                  <tr>
                    <td><%= student.student_number %></td>
                    <td><%= student.first_name %> <%= student.last_name %></td>
                    <td><%= student.Programme.name.split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
                       %></td>
                    <td><%= student.graduation_year %></td>
                    <td>
                      <button class="btn btn-secondary btn-sm" disabled>
                        No Access
                      </button>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>

          <% } else { %>
            <p class="text-muted mb-0">
              No other students found.
            </p>
          <% } %>

        </div>
      </div>
    </div>



    <div class="col-12">

      <div class="card shadow-sm">

        <div class="card-header bg-white">
          <h5 class="mb-0">Inactive Students</h5>
        </div>

        <div class="card-body table-responsive">

          <% if (inactiveStudents.length > 0) { %>

            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Student Number</th>
                  <th>Name</th>
                  <th>Programme</th>
                  <th>Graduation Year</th>
                  <th>Action</th>
                </tr>
              </thead>

              <tbody>
                <% inactiveStudents.forEach(student => { %>
                  <tr class="text-muted">
                    <td><%= student.student_number %></td>
                    <td><%= student.first_name %> <%= student.last_name %></td>
                    <td><%= student.Programme.name .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')

                      %></td>
                    <td><%= student.graduation_year %></td>
                    <td>
                      <a href="/academic/studentProfile/<%= student.id %>"
                         class="btn btn-outline-secondary btn-sm">
                        View
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>

          <% } else { %>
            <p class="text-muted mb-0">
              No inactive students found.
            </p>
          <% } %>

        </div>
      </div>
    </div>

  </div>
</div>



  
<div class="pageSpacing"></div>

  </div>


















  </body>
</html>