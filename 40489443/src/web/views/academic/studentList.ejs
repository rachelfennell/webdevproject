<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academic Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container">
      <a class="navbar-brand" href="#">HEdClass</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link">Logged in as <%= user.first_name %> <%= user.last_name %></span>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1>All Students</h1>
  
    </div>

    <% if (message) { %>
      <div class="alert alert-info"><%= message %></div>
    <% } %>

    <h4>Your Students</h4>
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Student Number</th>
          <th>Name</th>
          <th>Programme</th>
          <th>Graduation Year</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (assignedStudents.length > 0) { %>
          <% assignedStudents.forEach(student => { %>
            <tr>
              <td><%= student.student_number %></td>
              <td><%= student.first_name %> <%= student.last_name %></td>
              <td><%= student.Programme.name %></td>
              <td><%= student.graduation_year %></td>
              <td>
                <a href="/academic/studentProfile/<%= student.id %>">
                  <button type="button" class="btn btn-info btn-sm">View</button>
                </a>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5">No students assigned to your programmes.</td>
          </tr>
        <% } %>
      </tbody>
    </table>

    <h4 class="mt-4">Other Students</h4>
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Student Number</th>
          <th>Name</th>
          <th>Programme</th>
          <th>Graduation Year</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (unassignedStudents.length > 0) { %>
          <% unassignedStudents.forEach(student => { %>
            <tr>
              <td><%= student.student_number %></td>
              <td><%= student.first_name %> <%= student.last_name %></td>
              <td><%= student.Programme.name %></td>
              <td><%= student.graduation_year %></td>
              <td>
                <button type="button" class="btn btn-secondary btn-sm" disabled>
                  No Access
                </button>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5">No other students found.</td>
          </tr>
        <% } %>
      </tbody>
    </table>

<%# Inactive Students %>
    <h4 class="mt-4">Inactive Students</h4>
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Student Number</th>
          <th>Name</th>
          <th>Programme</th>
          <th>Graduation Year</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (inactiveStudents.length > 0) { %>
          <% inactiveStudents.forEach(student => { %>
            <tr class="text-muted">
              <td><%= student.student_number %></td>
              <td><%= student.first_name %> <%= student.last_name %></td>
              <td><%= student.Programme.name %></td>
              <td><%= student.graduation_year %></td>
              <td>
                <a href="/academic/studentProfile/<%= student.id %>">
                  <button type="button" class="btn btn-outline-secondary btn-sm">View</button>
                </a>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5">No inactive students found.</td>
          </tr>
        <% } %>
      </tbody>
    </table>




    <a href="/academic/dashboard" class="btn btn-secondary mt-3">Back to Dashboard</a>

  </div>


















  </body>
</html>