<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academic Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container">
      <a class="navbar-brand" href="#">HEdClass</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link">Logged in as <%= user.first_name %> <%= user.last_name %></span>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container">

    <%# Student Details %>
    <div>
      <h1>Student Profile: <%= student.first_name %> <%= student.last_name %></h1>
      <p>Student Number: <%= student.student_number %></p>
      <p>Date of Birth: <%= student.dob %></p>
      <p>Programme: <%= student.Programme.name %> (<%= student.Programme.programme_code %>)</p>
      <p>Degree Type: <%= student.Programme.degree_type %></p>
      <p>School: <%= student.Programme.school %></p>
      <p>Enrolled Date: <%= student.enrolled_date %></p>
      <p>Graduation Year: <%= student.graduation_year %></p>
      <p>Status: <%= student.active_student ? 'Active' : 'Inactive' %></p>
    </div>

    <%# Results %>
    <div>
      <h2>Module Results</h2>

      <%# Year 1 %>
      <h3>Year 1</h3>
      <% const y1Results = student.Results ? student.Results.filter(r => r.year_level == '1') : [] %>
      <% if (y1Results.length > 0) { %>
        <table class="table">
          <thead>
            <tr>
              <th>Module Name</th>
              <th>Module Code</th>
              <th>Mark</th>
              <th>Resit</th>
            </tr>
          </thead>
          <tbody>
            <% y1Results.forEach(result => { %>
              <tr>
                <td><%= result.Module.name %></td>
                <td><%= result.Module.module_code %></td>
                <td><%= result.mark %>%</td>
                <td><%= result.is_resit ? 'Yes' : 'No' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p>No Year 1 results recorded.</p>
      <% } %>

      <%# Year 2 %>
      <h3>Year 2</h3>
      <% const y2Results = student.Results ? student.Results.filter(r => r.year_level == '2') : [] %>
      <% if (y2Results.length > 0) { %>
        <table class="table">
          <thead>
            <tr>
              <th>Module Name</th>
              <th>Module Code</th>
              <th>Mark</th>
              <th>Resit</th>
            </tr>
          </thead>
          <tbody>
            <% y2Results.forEach(result => { %>
              <tr>
                <td><%= result.Module.name %></td>
                <td><%= result.Module.module_code %></td>
                <td><%= result.mark %>%</td>
                <td><%= result.is_resit ? 'Yes' : 'No' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p>No Year 2 results recorded.</p>
      <% } %>

      <%# Year 3 %>
      <h3>Year 3</h3>
      <% const y3Results = student.Results ? student.Results.filter(r => r.year_level == '3') : [] %>
      <% if (y3Results.length > 0) { %>
        <table class="table">
          <thead>
            <tr>
              <th>Module Name</th>
              <th>Module Code</th>
              <th>Mark</th>
              <th>Resit</th>
            </tr>
          </thead>
          <tbody>
            <% y3Results.forEach(result => { %>
              <tr>
                <td><%= result.Module.name %></td>
                <td><%= result.Module.module_code %></td>
                <td><%= result.mark %>%</td>
                <td><%= result.is_resit ? 'Yes' : 'No' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p>No Year 3 results recorded.</p>
      <% } %>
    </div>

    <%# Classification %>
    <div>
      <h2>Classification</h2>
      <% if (student.Classification) { %>
        <p>Year 2 Average: <%= student.Classification.y2_average %>%</p>
        <p>Year 3 Average: <%= student.Classification.y3_average %>%</p>
        <p>Final Average: <%= student.Classification.final_average %>%</p>
        <p>Proposed Outcome: <%= student.Classification.proposed_outcome %></p>
        <p>Final Outcome: <%= student.Classification.final_outcome %></p>
        <% if (student.Classification.is_overridden) { %>
          <p>Manually Overridden: Yes</p>
          <p>Rationale: <%= student.Classification.rationale %></p>
        <% } %>
      <% } else { %>
        <p>No classification has been run for this student yet.</p>
      <% } %>
    </div>

    <%# Action Buttons %>
    <div class="mt-3 d-flex gap-2">
      <a href="/academic/editStudent/<%= student.id %>" class="btn btn-primary">Edit Student</a>
      <a href="/academic/editResults//<%= student.id %>" class="btn btn-info">Manage Results</a>
      <a href="/academic/calculateClassifications/<%= student.id %>" class="btn btn-success">Something for Classification???</a>
    </div>

    <div class="mt-3">
      <a href="/academic/studentList" class="btn btn-secondary">Back to Student List</a>
    </div>

  </div>

</body>
</html>