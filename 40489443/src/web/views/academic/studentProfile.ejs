<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Profile - HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
    <%# Top row %>
      <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
        <a class="navbar-brand mb-0" href="/academic/dashboard">
          <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
        </a>
        <span class="text-white">Logged in as <%= user.first_name %>
            <%= user.last_name %></span>
      </div>

      <%# Bottom row %>
        <div class="w-100 py-2 d-flex justify-content-end">
          <ul class="navbar-nav flex-row gap-3">
            <li class="nav-item">
              <a class="nav-link" href="/academic/dashboard">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/academic/studentList">Students List</a>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                Assigned Programmes
              </a>
              <ul class="dropdown-menu">
                <% if (userProgrammes && userProgrammes.length> 0) { %>
                  <% userProgrammes.forEach(userProgramme=> { %>
                    <li>
                      <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
                        <%= userProgramme.Programme.name .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>


<div class="container mt-5">

  <div class="row g-4">


   
    <div class="col-12 col-lg-4">

      <div class="card shadow-sm p-3">

        <div class="d-flex justify-content-between align-items-center">
          <h4 class="mb-0">
            <%= student.first_name %> <%= student.last_name %>
          </h4>

          <a href="/academic/editStudent/<%= student.id %>"
             class="btn btn-sm dashboardButton">
            Edit Student
          </a>
        </div>

        <hr>

        <p><strong>Student Number:</strong> <%= student.student_number %></p>
        <p><strong>Date of Birth:</strong> <%= student.dob %></p>

        <p>
          <strong>Programme:</strong>
          <%= student.Programme.name.split(' ')
            .map(word => word.charAt(0).toUpperCase() + word.slice(1))
            .join(' ')
          %>
          (<%= student.Programme.programme_code %>)
        </p>

        <p><strong>Degree Type:</strong> <%= student.Programme.degree_type %></p>
        <p><strong>School:</strong> <%= student.Programme.school %></p>

        <p><strong>Enrolled Date:</strong> <%= student.enrolled_date.toLocaleDateString('en-GB') %>
                          </p>
                          <p><strong>Graduation Year:</strong>
                            <%= student.graduation_year %>
                          </p>

                          <p>
                            <strong>Status:</strong>
                            <%= student.active_student ? 'Active' : 'Inactive' %>
                          </p>

        </div>
        </div>


        <!-- RIGHT-->
        <div class="col-12 col-lg-8">



          <div class="card shadow-sm mb-4">

            <div class="card-header bg-white d-flex justify-content-between align-items-center">
              <h5 class="mb-0">Module Results</h5>

              <a href="/academic/editResults/<%= student.id %>" class="btn btn-info">
                Edit Results
              </a>
            </div>

            <div class="card-body">


              <% const y1Results=student.Results ? student.Results.filter(r=> r.year_level == '1') : [] %>

                <h6>Year 1</h6>
                <% if (y1Results.length> 0) { %>

                  <div class="table-responsive mb-4">
                    <table class="table table-hover align-middle">
                      <thead class="table-light">
                        <tr>
                          <th>Module</th>
                          <th>Code</th>
                          <th>Credits</th>
                          <th>Mark</th>
                          <th>Resit</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% y1Results.forEach(result=> { %>
                          <tr>
                            <td>
                              <%= result.Module.name %>
                            </td>
                            <td>
                              <%= result.Module.module_code %>
                            </td>
                            <td>
                              <%= result.Module.credits %>
                            </td>
                            <td>
                              <%= result.mark %>%
                            </td>
                            <td>
                              <%= result.is_resit ? 'Yes' : 'No' %>
                            </td>
                          </tr>
                          <% }) %>
                      </tbody>
                    </table>
                  </div>

                  <% } else { %>
                    <p class="text-muted">No Year 1 results recorded.</p>
                    <% } %>


                      <% const y2Results=student.Results ? student.Results.filter(r=> r.year_level == '2') : [] %>

                        <h6>Year 2</h6>
                        <% if (y2Results.length> 0) { %>

                          <div class="table-responsive mb-4">
                            <table class="table table-hover align-middle">
                              <thead class="table-light">
                                <tr>
                                  <th>Module</th>
                                  <th>Code</th>
                                  <th>Credits</th>
                                  <th>Mark</th>
                                  <th>Resit</th>
                                </tr>
                              </thead>
                              <tbody>
                                <% y2Results.forEach(result=> { %>
                                  <tr>
                                    <td>
                                      <%= result.Module.name %>
                                    </td>
                                    <td>
                                      <%= result.Module.module_code %>
                                    </td>
                                    <td>
                                      <%= result.Module.credits %>
                                    </td>
                                    <td>
                                      <%= result.mark %>%
                                    </td>
                                    <td>
                                      <%= result.is_resit ? 'Yes' : 'No' %>
                                    </td>
                                  </tr>
                                  <% }) %>
                              </tbody>
                            </table>
                          </div>

                          <% } else { %>
                            <p class="text-muted">No Year 2 results recorded.</p>
                            <% } %>


                              <% const y3Results=student.Results ? student.Results.filter(r=> r.year_level == '3') : []
                                %>

                                <h6>Year 3</h6>
                                <% if (y3Results.length> 0) { %>

                                  <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                      <thead class="table-light">
                                        <tr>
                                          <th>Module</th>
                                          <th>Code</th>
                                          <th>Credits</th>
                                          <th>Mark</th>
                                          <th>Resit</th>
                                        </tr>
                                      </thead>
                                      <tbody>
                                        <% y3Results.forEach(result=> { %>
                                          <tr>
                                            <td>
                                              <%= result.Module.name %>
                                            </td>
                                            <td>
                                              <%= result.Module.module_code %>
                                            </td>
                                            <td>
                                              <%= result.Module.credits %>
                                            </td>
                                            <td>
                                              <%= result.mark %>%
                                            </td>
                                            <td>
                                              <%= result.is_resit ? 'Yes' : 'No' %>
                                            </td>
                                          </tr>
                                          <% }) %>
                                      </tbody>
                                    </table>
                                  </div>

                                  <% } else { %>
                                    <p class="text-muted">No Year 3 results recorded.</p>
                                    <% } %>

            </div>
          </div>



          <div class="card shadow-sm mb-4">

            <div class="card-header bg-white d-flex justify-content-between align-items-center">
              <h5 class="mb-0">Classification</h5>

              <a href="/academic/studentClassification/<%= student.id %>" class="btn btn-success">
                Run Classification
              </a>
            </div>

            <div class="card-body">

              <% if (student.Classification) { %>

                <p><strong>Year 2 Average:</strong>
                  <%= student.Classification.y2_average %>%
                </p>
                <p><strong>Year 3 Average:</strong>
                  <%= student.Classification.y3_average %>%
                </p>
                <p><strong>Final Average:</strong>
                  <%= student.Classification.final_average %>%
                </p>

                <p><strong>Proposed Outcome:</strong>
                  <%= student.Classification.proposed_outcome %>
                </p>
                <p><strong>Final Outcome:</strong>
                  <%= student.Classification.final_outcome %>
                </p>

                <% if (student.Classification.is_overridden) { %>
                  <p><strong>Manually Overridden:</strong> Yes</p>
                  <p><strong>Rationale:</strong>
                    <%= student.Classification.rationale %>
                  </p>
                  <% } %>

                    <% } else { %>
                      <p class="text-muted">No classification has been run for this student yet.</p>
                      <% } %>

            </div>
          </div>

        </div>
        </div>
        </div>


        <div class="container mt-5 mb-5">
          <div class="d-flex justify-content-end">
            <button onclick="history.back()" class="btn dashboardButton">
              Back to Student List
            </button>

          </div>
        </div>



        <div class="pageSpacing"></div>

</body>

</html>