<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academic Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body><nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
 <%# Top row %>
    <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
      <a class="navbar-brand mb-0" href="/academic/dashboard">
        <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
      </a>
      <span class="text-white">Logged in as <%= user.first_name %> <%= user.last_name %></span>
    </div>

  <%# Bottom row %>
  <div class="w-100 py-2 d-flex justify-content-end">
      <ul class="navbar-nav flex-row gap-3">
        <li class="nav-item">
        <a class="nav-link" href="/academic/dashboard">Home</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/studentList">Students List</a>
      </li>
<li class="nav-item dropdown">
  <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
    Assigned Programmes
  </a>
  <ul class="dropdown-menu">
  <% if (userProgrammes && userProgrammes.length > 0) { %>
    <% userProgrammes.forEach(userProgramme => { %>
      <li>
        <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
          <%= userProgramme.Programme.name  .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>

<div class="container mt-4">

  <div class="card shadow-sm p-3 mb-4">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h4 class="mb-0"><%= programme.name.split(' ')
            .map(word => word.charAt(0).toUpperCase() + word.slice(1))
            .join(' ') %></h4>
  
      </div>
      <div class="text-end">
        <p class="mb-0"><strong>Code:</strong> <%= programme.programme_code %></p>
      </div>
    </div>
  </div>



  


  
  <div class="card shadow-sm mb-4">

    <div class="card-header bg-white">
      <h5 class="mb-0">Run Classification for Entire Cohort</h5>
    </div>

    <div class="card-body">

      <p class="text-muted">
        Run the classification engine for all
        <strong><%= students.length %></strong> active students.
        This will recalculate results and reset any manual overrides. 
        Click on the students profile to run an individual students classification engine.
      </p>

      <form action="/academic/programmeClassification/<%= programme.id %>" method="POST">
        <button
          type="submit"
          class="btn btn-primary"
          onclick="return confirm('Run classification for all <%= students.length %> students? This will reset overrides.')">

          Run Classification for All Students

        </button>
      </form>

    </div>
  </div>


 
  <div class="card shadow-sm">

    <div class="card-header bg-white d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Classification Results</h5>
    </div>

    <div class="card-body table-responsive">

      <% if (students.length === 0) { %>

        <p class="text-muted mb-0">No active students on this programme.</p>

      <% } else { %>

        <table class="table table-hover align-middle mb-0">

          <thead class="table-light">
            <tr>
              <th>Student Number</th>
              <th>Name</th>
              <th>Proposed Outcome</th>
              <th>Final Outcome</th>
              <th>Flagged</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>

            <% students.forEach(student => { %>

              <tr>

                <td><%= student.student_number %></td>

                <td>
                  <%= student.first_name %> <%= student.last_name %>
                </td>


                <% if (student.Classification) { %>

                  
                  <td>
                    <%= student.Classification.proposed_outcome || '—' %>
                  </td>

            
                  <td>
                    <% const outcome = student.Classification.final_outcome; %>

                    <% if (outcome === 'First Class Honours') { %>
                      <span class="badge bg-success"><%= outcome %></span>

                    <% } else if (outcome === 'Upper Second Class (2:1)') { %>
                      <span class="badge bg-primary"><%= outcome %></span>

                    <% } else if (outcome === 'Lower Second Class (2:2)') { %>
                      <span class="badge bg-info"><%= outcome %></span>

                    <% } else if (outcome === 'Third Class Honours') { %>
                      <span class="badge bg-warning text-dark"><%= outcome %></span>

                    <% } else if (outcome === 'Fail' || outcome === 'Not Eligible') { %>
                      <span class="badge bg-danger"><%= outcome %></span>

                    <% } else { %>
                      <span class="badge bg-secondary">—</span>
                    <% } %>
                  </td>

                 
                  <td>
                    <% if (student.Classification.is_flagged) { %>
                      <span class="badge bg-danger">Flagged</span>
                    <% } else { %>
                      <span class="badge bg-secondary">No</span>
                    <% } %>
                  </td>

                <% } else { %>

                  <td>—</td>
                  <td><span class="badge bg-secondary">Not Run</span></td>
                  <td>—</td>

                <% } %>


               
                <td class="d-flex gap-2">

                  <a href="/academic/studentProfile/<%= student.id %>"
                     class="btn btn-secondary btn-sm">
                    Profile
                  </a>

                  <a href="/academic/studentClassification/<%= student.id %>"
                     class="btn dashboardButton btn-sm">
                    Classification
                  </a>

                </td>

              </tr>

            <% }) %>

          </tbody>

        </table>

      <% } %>

    </div>
  </div>

</div>
<div class="container mt-5 mb-5">
 
      <div class="d-flex justify-content-end">
          <a href="/academic/programmeDashboard/<%= programme.id %>" class="btn dashboardButton">
            Back to Programme Dashboard
          </a>
        



  </div>
</div>

<div class="pageSpacing"></div>

</body>
</html>