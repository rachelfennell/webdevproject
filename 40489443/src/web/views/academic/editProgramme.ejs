<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academic Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body><nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
 <%# Top row %>
    <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
      <a class="navbar-brand mb-0" href="/academic/dashboard">
        <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
      </a>
      <span class="text-white">Logged in as <%= user.first_name %> <%= user.last_name %></span>
    </div>

  <%# Bottom row %>
  <div class="w-100 py-2 d-flex justify-content-end">
      <ul class="navbar-nav flex-row gap-3">
        <li class="nav-item">
        <a class="nav-link" href="/academic/dashboard">Home</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/studentList">Students List</a>
      </li>
<li class="nav-item dropdown">
  <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
    Assigned Programmes
  </a>
  <ul class="dropdown-menu">
  <% if (userProgrammes && userProgrammes.length > 0) { %>
    <% userProgrammes.forEach(userProgramme => { %>
      <li>
        <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
          <%= userProgramme.Programme.name  .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>





  <div class="container mt-5">
    <div class="row g-4">

      <%# Left Column — Programme Details Form %>
      <div class="col-12 col-lg-4">
        <div class="card shadow-sm p-3">

          <div class="d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Edit Programme</h4>
          </div>

          <hr>

          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>

          <form action="/academic/editProgramme/<%= programme.id %>" method="POST">

            <div class="form-group mb-3">
              <label for="name">Name</label>
              <input type="text" class="form-control" id="name" name="name"
                value="<%= programme.name %>" required />
            </div>

            <div class="form-group mb-3">
              <label for="programme_code">Programme Code</label>
              <input type="text" class="form-control" id="programme_code" name="programme_code"
                value="<%= programme.programme_code %>" required />
            </div>

            <div class="form-group mb-3">
              <label for="degree_type">Degree Type</label>
              <select class="form-control" id="degree_type" name="degree_type" required>
                <option value="BSc" <%= programme.degree_type === 'BSc' ? 'selected' : '' %>>BSc</option>
                <option value="BA" <%= programme.degree_type === 'BA' ? 'selected' : '' %>>BA</option>
                <option value="LLB" <%= programme.degree_type === 'LLB' ? 'selected' : '' %>>LLB</option>
                <option value="BEng" <%= programme.degree_type === 'BEng' ? 'selected' : '' %>>BEng</option>
              </select>
            </div>

            <div class="form-group mb-3">
              <label for="school">School</label>
              <select class="form-control" id="school" name="school" required>
                <option value="EEECS" <%= programme.school === 'EEECS' ? 'selected' : '' %>>EEECS</option>
                <option value="Law" <%= programme.school === 'Law' ? 'selected' : '' %>>Law</option>
                <option value="Arts" <%= programme.school === 'Arts' ? 'selected' : '' %>>Arts</option>
              </select>
            </div>

            <div class="form-group mb-3">
              <label for="y2_weight">Year 2 Weight</label>
              <input type="number" step="0.01" class="form-control" id="y2_weight" name="y2_weight"
                value="<%= programme.y2_weight %>" min="0" max="1" required />
            </div>

            <div class="form-group mb-3">
              <label for="y3_weight">Year 3 Weight</label>
              <input type="number" step="0.01" class="form-control" id="y3_weight" name="y3_weight"
                value="<%= programme.y3_weight %>" min="0" max="1" required />
            </div>

            <div class="form-group mb-3">
              <label for="resit_cap">Resit Cap</label>
              <input type="number" class="form-control" id="resit_cap" name="resit_cap"
                value="<%= programme.resit_cap %>" min="0" max="100" required />
            </div>

            <div class="form-group mb-3">
              <label for="pass_mark">Pass Mark</label>
              <input type="number" class="form-control" id="pass_mark" name="pass_mark"
                value="<%= programme.pass_mark %>" min="0" max="100" required />
            </div>

            <div class="form-group mb-3">
              <label for="active">Active</label>
              <div>
                <input type="checkbox" id="active" name="active" value="on"
                  <%= programme.active ? 'checked' : '' %> />
              </div>
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn dashboardButton">Save Changes</button>
              <a href="/academic/programmeDashboard/<%= programme.id %>" class="btn btn-secondary">Cancel</a>
            </div>

          </form>
        </div>
      </div>

      <%# Right Column — Assigned Modules %>
      <div class="col-12 col-lg-8">
        <div class="card shadow-sm mb-4">
          <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Assigned Modules</h5>
            <button type="button" class="btn btn-success btn-sm"
              data-bs-toggle="modal" data-bs-target="#assignModule">
              + Assign Module
            </button>
          </div>
          <div class="card-body table-responsive">
            <% if (programme.Modules && programme.Modules.length > 0) { %>
              <table class="table table-hover align-middle">
                <thead class="table-light">
                  <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Year</th>
                    <th>Credits</th>
                    <th>Mandatory</th>
                    <th>Status</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% programme.Modules.forEach(module => { %>
                    <tr>
                      <td><%= module.name %></td>
                      <td><%= module.module_code %></td>
                      <td>Year <%= module.ProgrammeModule.year_level %></td>
                      <td><%= module.ProgrammeModule.credits %></td>
                      <td>
                        <% if (module.ProgrammeModule.mandatory) { %>
                          <span class="badge bg-primary">Mandatory</span>
                        <% } else { %>
                          <span class="badge bg-secondary">Optional</span>
                        <% } %>
                      </td>
                      <td>
                        <% if (module.ProgrammeModule.active) { %>
                          <span class="badge bg-success">Active</span>
                        <% } else { %>
                          <span class="badge bg-secondary">Inactive</span>
                        <% } %>
                      </td>
                      <td>
                        <form action="/academic/removeModule/<%= programme.id %>" method="POST">
                          <input type="hidden" name="moduleId" value="<%= module.id %>" />
                          <button type="submit" class="btn btn-danger btn-sm"
                            onclick="return confirm('Are you sure you want to unassign this module?')">
                            Unassign
                          </button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } else { %>
              <div class="alert alert-info mb-0">
                No modules currently assigned to this programme.
              </div>
            <% } %>
          </div>
        </div>

        <div class="d-flex justify-content-end">
          <a href="/academic/programmeDashboard/<%= programme.id %>" class="btn dashboardButton">
            Back to Programme Dashboard
          </a>
        </div>
      </div>

    </div>
  </div>

  <%# Assign Module Modal %>
  <div class="modal fade" id="assignModule" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Assign Module</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form action="/academic/assignModule/<%= programme.id %>" method="POST">

            <div class="mb-3">
              <label class="form-label">Select Module</label>
              <select name="moduleId" class="form-control" required>
                <option value="">Select a module</option>
                <% activeModules.forEach(module => { %>
                  <option value="<%= module.id %>">
                    <%= module.name %> — <%= module.module_code %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label">Year Level</label>
              <select class="form-control" name="year_level" required>
                <option value="1">Year 1</option>
                <option value="2">Year 2</option>
                <option value="3">Year 3</option>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label">Credits</label>
              <input type="number" class="form-control" name="credits" min="0" max="120" required />
            </div>

            <div class="mb-3">
              <label class="form-label">Mandatory</label>
              <select class="form-control" name="mandatory" required>
                <option value="true">Yes</option>
                <option value="false">No</option>
              </select>
            </div>

            <button type="submit" class="btn btn-primary w-100">Assign Module</button>

          </form>
        </div>
      </div>
    </div>
  </div>

  <div class="pageSpacing"></div>
</body>
</html>