<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= module.name %> Results | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container">
      <a class="navbar-brand" href="/academic/dashboard">HEdClass</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link">Logged in as <%= user.first_name %> <%= user.last_name %></span>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1><%= module.name %></h1>
        <p class="text-muted mb-0">Module Code: <%= module.module_code %></p>
        <% if (programmeModule) { %>
          <p class="text-muted mb-0">Year Level: Year <%= programmeModule.year_level %> | Credits: <%= programmeModule.credits %></p>
        <% } %>
        <p class="text-muted mb-0">Programme: <%= programme.name %></p>
      </div>
      <a href="/academic/programmeDashboard/<%= programme.id %>" class="btn btn-secondary">
        Back to Programme
      </a>
    </div>

    <% if (students.length === 0) { %>
      <div class="alert alert-info">No active students on this programme.</div>
    <% } else { %>
      <table class="table table-striped">
        <thead>
          <tr>
            <th>Student Number</th>
            <th>Name</th>
            <th>Original Mark</th>
            <th>Resit Mark</th>
            <th>Overall Mark</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(student => { %>
            <%
              const original = originalResults.find(r => r.student_id === student.id);
              const resit = resitResults.find(r => r.student_id === student.id);
              const allResults = [...originalResults, ...resitResults];
              const overallMark = getOverallMark(module.id, allResults.filter(r => r.student_id === student.id), programme.resit_cap);
            %>
            <tr>
              <td><%= student.student_number %></td>
              <td><%= student.first_name %> <%= student.last_name %></td>
              <td><%= original ? original.mark + '%' : '—' %></td>
              <td><%= resit ? resit.mark + '%' : '—' %></td>
              <td><%= overallMark !== null ? overallMark + '%' : '—' %></td>
              <td>
                <% if (overallMark !== null) { %>
                  <% if (overallMark >= programme.pass_mark) { %>
                    <span class="badge bg-success">Pass</span>
                  <% } else { %>
                    <span class="badge bg-danger">Fail</span>
                  <% } %>
                <% } else { %>
                  <span class="badge bg-secondary">No Result</span>
                <% } %>
              </td>
              <td>
                <a href="/academic/editResults/<%= student.id %>?from=/academic/moduleResults/<%= programme.id %>/<%= module.id %>"
                   class="btn btn-primary btn-sm">
                  Edit Results
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

  </div>

</body>
</html>