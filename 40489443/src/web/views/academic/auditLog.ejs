<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Audit Log Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body><nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
 <%# Top row %>
    <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
      <a class="navbar-brand mb-0" href="/academic/dashboard">
        <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
      </a>
      <span class="text-white">Logged in as <%= user.first_name %> <%= user.last_name %></span>
    </div>

  <%# Bottom row %>
  <div class="w-100 py-2 d-flex justify-content-end">
      <ul class="navbar-nav flex-row gap-3">
        <li class="nav-item">
        <a class="nav-link" href="/academic/dashboard">Home</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/studentList">Students List</a>
      </li>
<li class="nav-item dropdown">
  <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
    Assigned Programmes
  </a>
  <ul class="dropdown-menu">
  <% if (userProgrammes && userProgrammes.length > 0) { %>
    <% userProgrammes.forEach(userProgramme => { %>
      <li>
        <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
          <%= userProgramme.Programme.name  .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>



  <div class="container mt-5 mb-4">

    <% if (classifications.length === 0) { %>
      <div class="alert alert-info">
        No overrides or flags have been recorded yet.
      </div>
    <% } else { %>
      <div class="card">
        <div class="card-body p-0">
          <table class="table table-striped mb-0">
            <thead class="table table-striped mb-4">
              <tr>
                <th>Student Number</th>
                <th>Name</th>
                <th>Programme</th>
                <th>Proposed Outcome</th>
                <th>Final Outcome</th>
                <th>Overridden</th>
                <th>Flagged</th>
                <th>Rationale</th>
                <th>Classified At</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% classifications.forEach(c => { %>
                <tr>
                  <td><%= c.Student.student_number %></td>
                  <td><%= c.Student.first_name %> <%= c.Student.last_name %></td>
                  <td><%= c.Student.Programme.name  .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
                     %></td>
                  <td><%= c.proposed_outcome || '—' %></td>
                  <td>
                    <% if (c.final_outcome === 'First Class Honours') { %>
                      <span class="badge bg-success"><%= c.final_outcome %></span>
                    <% } else if (c.final_outcome === 'Upper Second Class (2:1)') { %>
                      <span class="badge bg-primary"><%= c.final_outcome %></span>
                    <% } else if (c.final_outcome === 'Lower Second Class (2:2)') { %>
                      <span class="badge bg-info"><%= c.final_outcome %></span>
                    <% } else if (c.final_outcome === 'Third Class Honours') { %>
                      <span class="badge bg-warning text-dark"><%= c.final_outcome %></span>
                    <% } else { %>
                      <span class="badge bg-danger"><%= c.final_outcome %></span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.is_overridden) { %>
                      <span class="badge bg-warning text-dark">Yes</span>
                    <% } else { %>
                      <span class="badge bg-secondary">No</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.is_flagged) { %>
                      <span class="badge bg-danger">Yes</span>
                    <% } else { %>
                      <span class="badge bg-secondary">No</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.rationale) { %>
                      <%= c.rationale %>
                    <% } else if (c.flag_reason) { %>
                      <%= c.flag_reason %>
                    <% } else { %>
                      —
                    <% } %>
                  </td>
                  <td>
                    <% if (c.classified_at) { %>
                      <%= new Date(c.classified_at).toLocaleDateString('en-GB') %>
                    <% } else { %>
                      —
                    <% } %>
                  </td>
                  <td>
                    <a href="/academic/studentClassification/<%= c.student_id %>" class="btn dashboardButton">
                      View
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

  </div>
<div class="pageSpacing"></div>

</body>
</html>