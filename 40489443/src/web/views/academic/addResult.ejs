<!-- views/academic/addResult.ejs -->
<h3>Add Result for <%= student.first_name %> <%= student.last_name %></h3>
<p><strong>Student Number:</strong> <%= student.student_number %></p>

<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<form method="POST" action="/academic/students/<%= student.id %>/results/add">
  <div class="mb-3">
    <label for="moduleId" class="form-label">Module</label>
    <select name="moduleId" id="moduleId" class="form-select" required>
      <% modules.forEach(module => { %>
        <option value="<%= module.id %>"><%= module.name %> (Year <%= module.year %>)</option>
      <% }) %>
    </select>
  </div>
  <div class="mb-3">
    <label for="mark" class="form-label">Mark</label>
    <input type="number" name="mark" id="mark" class="form-control" min="0" max="100" required>
  </div>
  <div class="mb-3">
    <label for="credits" class="form-label">Credits</label>
    <input type="number" name="credits" id="credits" class="form-control" min="0" max="60" required>
  </div>
  <button type="submit" class="btn btn-primary">Add Result</button>
  <a href="/academic/students/<%= student.id %>/results" class="btn btn-secondary">Cancel</a>
</form>