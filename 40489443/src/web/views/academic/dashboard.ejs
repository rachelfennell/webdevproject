<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academic Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
    <%# Top row %>
      <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
        <a class="navbar-brand mb-0" href="/academic/dashboard">
          <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
        </a>
        <span class="text-white">Logged in as <%= user.first_name %>
            <%= user.last_name %></span>
      </div>

      <%# Bottom row %>
        <div class="w-100 py-2 d-flex justify-content-end">
          <ul class="navbar-nav flex-row gap-3">
            <li class="nav-item">
              <a class="nav-link" href="/academic/dashboard">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/academic/studentList">Students List</a>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                Assigned Programmes
              </a>
              <ul class="dropdown-menu">
                <% if (userProgrammes && userProgrammes.length> 0) { %>
                  <% userProgrammes.forEach(userProgramme=> { %>
                    <li>
                      <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
                        <%= userProgramme.Programme.name .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>


<div class="container mt-4">
    <h2 class="text-center mb-4">Academic Administrator Dashboard</h2>
    <div class="row g-4">

      <%# Left Column %>
    <div class="col-12 col-lg-4">
      <div class="card shadow-sm p-3 mb-4">
      <h5>Manage Students</h5>
                  <p>View and edit student profiles and results</p>
          <a href="/academic/studentList" class="btn dashboardButton">Go</a>
        </div>

        <div class="card shadow-sm p-3 mb-4">
      <h5>Create a New Student</h5>
                  <p>Create a new student profile</p>
          <a href="/academic/createStudent" class="btn dashboardButton">Go</a>
        </div>
        <div class="card shadow-sm p-3 mb-4">
          <h5>Audit Log</h5>
          <p>View all overridden and flagged classifications across your programmes</p>
          <a href="/academic/auditLog" class="btn dashboardButton">Go</a>
        </div>
      </div>
  
<%# Right Column %>

    <div class="col-12 col-lg-8">

      
      <div class="card shadow-sm mb-4">

        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h4 class="mb-0">Assigned Programmes</h4>
    
    </div>
    
     <div class="card-body table-responsive">

    <%# Message if no programmes assigned %>
    <% if (message) { %>
      <div class="alert alert-info"><%= message %></div>
    <% } %>

       
    <% if (programmes && programmes.length > 0) { %>
      
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Programme Name</th>
                <th>Programme Code</th>
                <th>Degree Type</th>
                <th>School</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% programmes.forEach(userProgramme => { %>
                <tr>
                  <td><%= userProgramme.Programme.name .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
                  </td>
                  <td><%= userProgramme.Programme.programme_code %></td>
                  <td><%= userProgramme.Programme.degree_type %></td>
                  <td><%= userProgramme.Programme.school %></td>
                  <td>
                    <a href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>" 
                       class="btn dashboardButton">
                      View Programme
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
    <% } %>
    </div>
</div>
</div>
</div>


<div class="pageSpacing"></div>

 
</body>
</html>