<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academic Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container">
      <a class="navbar-brand" href="#">HEdClass</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link">Logged in as <%= user.first_name %> <%= user.last_name %></span>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

<div class="container">
    <header class="my-4">
      <h1>Welcome, <%= userName %>!</h1>
    </header>

    <h2>Your Assigned Programmes</h2>
    
    <% if (message) { %>
        <div class="alert alert-danger"><%= message %></div>
    <% } %>

    <% if (programmes && programmes.length > 0) { %>
        <table class="table table-striped table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th>Programme Name</th>
                    <th>Programme Code</th>
                    <th>Actions</th> <
                </tr>
            </thead>
            <tbody>
                <% programmes.forEach(userProgramme => { %>
                    <tr>
                        <td><%= userProgramme.Programme.name %></td>
                        <td><%= userProgramme.Programme.programme_code %></td>
                        <td>
    
    <a href="/programmeDashboard/<%= userProgramme.Programme.id %>" class="btn btn-info btn-sm">More Info</a>
</td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } else { %>
        <p>You are not assigned to any programmes.</p>
    <% } %>
  </div>

 
</body>
</html>