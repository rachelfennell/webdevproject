<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= programme.name %> | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container">
      <a class="navbar-brand" href="/academic/dashboard">HEdClass</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link">Logged in as <%= user.first_name %> <%= user.last_name %></span>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container">

    <header class="my-4">
      <h1><%= programme.name %> Dashboard</h1>
      <p>Programme Code: <%= programme.programme_code %></p>
      <p>Degree Type: <%= programme.degree_type %></p>
      <p>School: <%= programme.school %></p>
    </header>

    <a href="/academic/editProgramme/<%= programme.id %>" class="btn btn-primary mb-4">Edit Programme</a>

    <%# Programme Details %>
    <div class="row mt-2 mb-4">
      <div class="col-md-3">
        <p class="text-muted mb-1">Status</p>
        <% if (programme.active) { %>
          <span class="badge bg-success">Active</span>
        <% } else { %>
          <span class="badge bg-secondary">Inactive</span>
        <% } %>
      </div>
      <div class="col-md-3">
        <p class="text-muted mb-1">Year 2 Weight</p>
        <p><%= (programme.y2_weight * 100).toFixed(0) %>%</p>
      </div>
      <div class="col-md-3">
        <p class="text-muted mb-1">Year 3 Weight</p>
        <p><%= (programme.y3_weight * 100).toFixed(0) %>%</p>
      </div>
      <div class="col-md-3">
        <p class="text-muted mb-1">Resit Cap</p>
        <p><%= programme.resit_cap %>%</p>
      </div>
      <div class="col-md-3">
        <p class="text-muted mb-1">Pass Mark</p>
        <p><%= programme.pass_mark %>%</p>
      </div>
    </div>

    <%# Student Information %>
    <div class="mt-4">
      <h2>Student Information</h2>
      <p><strong>Number of Active Students:</strong> <%= students.length %></p>
      <a href="/academic/programmeStudentList/<%= programme.id %>" class="btn btn-primary">
        View Student List
      </a>
    </div>

    <div class="mt-3">
    <a href="/academic/programmeClassification/<%= programme.id %>" class="btn btn-success mt-3">
  Run Programme Classification
</a></div>

    <%# Flagged Students %>
    <div class="mt-4">
      <h2>Flagged Students</h2>

      <%
        const flagged = students.filter(student => {
          if (student.Results.length === 0) return true;
          const moduleIds = [...new Set(student.Results.map(r => r.module_id))];
          return moduleIds.some(moduleId => {
            const effectiveMark = getOverallMark(moduleId, student.Results, programme.resit_cap);
            return effectiveMark !== null && effectiveMark < programme.pass_mark;
          });
        });
      %>

      <% if (flagged.length === 0) { %>
        <div class="alert alert-success">No students are currently flagged.</div>
      <% } else { %>
        <table class="table table-striped">
          <thead>
            <tr>
              <th>Student Number</th>
              <th>Name</th>
              <th>Flag</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% flagged.forEach(student => { %>
              <tr>
                <td><%= student.student_number %></td>
                <td><%= student.first_name %> <%= student.last_name %></td>
                <td>
                  <% if (student.Results.length === 0) { %>
                    <span class="badge bg-warning text-dark">No Results Entered</span>
                  <% } else { %>
                    <span class="badge bg-danger">Failing Module</span>
                  <% } %>
                </td>
                <td>
                  <a href="/academic/studentProfile/<%= student.id %>" class="btn btn-info btn-sm">
                    View Student Profile
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <%# Active Modules %>
    <div class="mt-4">
      <h2>Modules</h2>
      <h3>Currently Assigned Modules</h3>
      <% if (programme.Modules && programme.Modules.length > 0) { %>
        <table class="table">
          <thead>
            <tr>
              <th>Module Name</th>
              <th>Module Code</th>
              <th>Year Level</th>
              <th>Credits</th>
              <th>Mandatory</th>
              <th>Results</th>
            </tr>
          </thead>
          <tbody>
            <% programme.Modules.forEach(module => { %>
              <% if (module.ProgrammeModule.active) { %>
                <tr>
                  <td><%= module.name %></td>
                  <td><%= module.module_code %></td>
                  <td>Year <%= module.ProgrammeModule.year_level %></td>
                  <td><%= module.ProgrammeModule.credits %></td>
                  <td>
                    <% if (module.ProgrammeModule.mandatory) { %>
                      <span class="badge bg-primary">Mandatory</span>
                    <% } else { %>
                      <span class="badge bg-secondary">Optional</span>
                    <% } %>
                  </td>
                  <td>
                    <a href="/academic/moduleResults/<%= programme.id %>/<%= module.id %>"
                       class="btn btn-info btn-sm">
                      View Results
                    </a>
                  </td>
                </tr>
              <% } %>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p>No active modules assigned to this programme.</p>
      <% } %>

      <%# Inactive Modules %>
      <h3>Inactive Modules</h3>
      <% const inactiveModules = programme.Modules ? programme.Modules.filter(m => !m.ProgrammeModule.active) : [] %>
      <% if (inactiveModules.length > 0) { %>
        <table class="table">
          <thead>
            <tr>
              <th>Module Name</th>
              <th>Module Code</th>
              <th>Year Level</th>
              <th>Credits</th>
            </tr>
          </thead>
          <tbody>
            <% inactiveModules.forEach(module => { %>
              <tr class="text-muted">
                <td><%= module.name %></td>
                <td><%= module.module_code %></td>
                <td>Year <%= module.ProgrammeModule.year_level %></td>
                <td><%= module.ProgrammeModule.credits %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p>No inactive modules.</p>
      <% } %>
    </div>



    <footer class="mt-4">
      <a href="/academic/dashboard" class="btn btn-secondary">Back to Dashboard</a>
    </footer>

  </div>

</body>
</html>