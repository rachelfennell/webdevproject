<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academic Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body><nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
 <%# Top row %>
    <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
      <a class="navbar-brand mb-0" href="/academic/dashboard">
        <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
      </a>
      <span class="text-white">Logged in as <%= user.first_name %> <%= user.last_name %></span>
    </div>

  <%# Bottom row %>
  <div class="w-100 py-2 d-flex justify-content-end">
      <ul class="navbar-nav flex-row gap-3">
        <li class="nav-item">
        <a class="nav-link" href="/academic/dashboard">Home</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/studentList">Students List</a>
      </li>
<li class="nav-item dropdown">
  <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
    Assigned Programmes
  </a>
  <ul class="dropdown-menu">
  <% if (userProgrammes && userProgrammes.length > 0) { %>
    <% userProgrammes.forEach(userProgramme => { %>
      <li>
        <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
          <%= userProgramme.Programme.name  .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>

<div class="container mt-5">

  <div class="row g-4">

    <!-- LEFT -->
    <div class="col-12 col-lg-4">

      <div class="card shadow-sm p-3">

        <div class="d-flex justify-content-between align-items-center">
          <h4 class="mb-0">
            <%= programme.name.split(' ')
              .map(word => word.charAt(0).toUpperCase() + word.slice(1))
              .join(' ') %>
          </h4>
          <a href="/academic/editProgramme/<%= programme.id %>" class="btn btn-sm dashboardButton">
    Edit
  </a>
        </div>

        <hr>

        <p><strong>Code:</strong> <%= programme.programme_code %></p>
        <p><strong>Degree:</strong> <%= programme.degree_type %></p>
        <p><strong>School:</strong> <%= programme.school %></p>
        <p><strong>Status:</strong> <%= programme.active ? 'Active' : 'Inactive' %></p>
        <p><strong>Pass Mark:</strong> <%= programme.pass_mark %>%</p>
        <p><strong>Resit Cap:</strong> <%= programme.resit_cap %>%</p>
        <p><strong>Y2 Weight:</strong> <%= (programme.y2_weight * 100).toFixed(0) %>%</p>
        <p><strong>Y3 Weight:</strong> <%= (programme.y3_weight * 100).toFixed(0) %>%</p>

      </div>

   <div class="card shadow-sm p-3 mt-3">
    <h5 class="mb-0">Programme Classification</h5>
     <p>Click this button to run the programme classification for the entire active student cohort</p>
        <a href="/academic/programmeClassification/<%= programme.id %>" class="btn btn-success btn-sm w-100">
          Run Programme Classification </a>
      </div>



    </div>

    <!-- RIGHT -->
    <div class="col-12 col-lg-8">

      <div class="card shadow-sm mb-4">

    <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Students (<%= students.length %> active)</h5>
          <a href="/academic/programmeStudentList/<%= programme.id %>" class="btn btn-sm dashboardButton">
            View All
          </a>
        </div>

     

      </div>

     
      <div class="card shadow-sm mb-4">

        <div class="card-header bg-white">
          <h5 class="mb-0">Flagged Students</h5>
        </div>

        <%
          const flagged = students.filter(student => {
            if (!student.Results || student.Results.length === 0) return true;
            const moduleIds = [...new Set(student.Results.map(r => r.module_id))];
            return moduleIds.some(moduleId => {
              const effectiveMark = getOverallMark(moduleId, student.Results, programme.resit_cap);
              return effectiveMark !== null && effectiveMark < programme.pass_mark;
            });
          });
        %>

        <div class="card-body table-responsive">

          <% if (flagged.length === 0) { %>
            <div class="alert alert-success mb-0">No flagged students.</div>
          <% } else { %>
            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Student</th>
                  <th>Number</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% flagged.forEach(student => { %>
                  <tr>
                    <td><%= student.first_name %> <%= student.last_name %></td>
                    <td><%= student.student_number %></td>
                    <td>
                      <% if (student.Results.length === 0) { %>
                        <span class="badge bg-warning text-dark">No Results</span>
                      <% } else { %>
                        <span class="badge bg-danger">Flagged</span>
                      <% } %>
                    </td>
                    <td>
                      <a href="/academic/studentProfile/<%= student.id %>" class="btn btn-info btn-sm">View</a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>

        </div>
      </div>

     
      <%
        const year1Active = programme.Modules.filter(m => m.ProgrammeModule.year_level == 1 && m.ProgrammeModule.active);
const year1Inactive = programme.Modules.filter(m => m.ProgrammeModule.year_level == 1 && !m.ProgrammeModule.active);

      %>
      <% if (year1Active.length > 0 || year1Inactive.length > 0) { %>
      <div class="card shadow-sm mb-4">

        <div class="card-header bg-white">
          <h5 class="mb-0">Year 1 Modules</h5>
        </div>

        <div class="card-body">
          <% if (year1Active.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Credits</th>
                    <th>Type</th>
                    <th>Results</th>
                  </tr>
                </thead>
                <tbody>
                  <% year1Active.forEach(module => { %>
                    <tr>
                      <td><%= module.name %></td>
                      <td><%= module.module_code %></td>
                      <td><%= module.ProgrammeModule.credits %></td>
                      <td>
                        <% if (module.ProgrammeModule.mandatory) { %>
                          <span class="badge bg-primary">Mandatory</span>
                        <% } else { %>
                          <span class="badge bg-secondary">Optional</span>
                        <% } %>
                      </td>
                      <td>
                        <a href="/academic/moduleResults/<%= programme.id %>/<%= module.id %>" class="btn btn-sm dashboardButton">View</a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>

          <% if (year1Inactive.length > 0) { %>
            <h6 class="mt-3 text-muted">Inactive</h6>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Credits</th>
                  </tr>
                </thead>
                <tbody>
                  <% year1Inactive.forEach(module => { %>
                    <tr class="text-muted">
                      <td><%= module.name %></td>
                      <td><%= module.module_code %></td>
                      <td><%= module.ProgrammeModule.credits %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

      </div>
      <% } %>

      <%
        const year2Active = programme.Modules.filter(m => m.ProgrammeModule.year_level == 2 && m.ProgrammeModule.active);
const year2Inactive = programme.Modules.filter(m => m.ProgrammeModule.year_level == 2 && !m.ProgrammeModule.active);
      %>
      <% if (year2Active.length > 0 || year2Inactive.length > 0) { %>
      <div class="card shadow-sm mb-4">

        <div class="card-header bg-white">
          <h5 class="mb-0">Year 2 Modules</h5>
        </div>

        <div class="card-body">
          <% if (year2Active.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Credits</th>
                    <th>Type</th>
                    <th>Results</th>
                  </tr>
                </thead>
                <tbody>
                  <% year2Active.forEach(module => { %>
                    <tr>
                      <td><%= module.name %></td>
                      <td><%= module.module_code %></td>
                      <td><%= module.ProgrammeModule.credits %></td>
                      <td>
                        <% if (module.ProgrammeModule.mandatory) { %>
                          <span class="badge bg-primary">Mandatory</span>
                        <% } else { %>
                          <span class="badge bg-secondary">Optional</span>
                        <% } %>
                      </td>
                      <td>
                        <a href="/academic/moduleResults/<%= programme.id %>/<%= module.id %>" class="btn btn-sm dashboardButton">View</a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>

          <% if (year2Inactive.length > 0) { %>
            <h6 class="mt-3 text-muted">Inactive</h6>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Credits</th>
                  </tr>
                </thead>
                <tbody>
                  <% year2Inactive.forEach(module => { %>
                    <tr class="text-muted">
                      <td><%= module.name %></td>
                      <td><%= module.module_code %></td>
                      <td><%= module.ProgrammeModule.credits %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

      </div>
      <% } %>

      
      <%
        const year3Active = programme.Modules.filter(m => m.ProgrammeModule.year_level == 3 && m.ProgrammeModule.active);
const year3Inactive = programme.Modules.filter(m => m.ProgrammeModule.year_level == 3 && !m.ProgrammeModule.active);
      %>
      <% if (year3Active.length > 0 || year3Inactive.length > 0) { %>
      <div class="card shadow-sm mb-4">

        <div class="card-header bg-white">
          <h5 class="mb-0">Year 3 Modules</h5>
        </div>

        <div class="card-body">
          <% if (year3Active.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Credits</th>
                    <th>Type</th>
                    <th>Results</th>
                  </tr>
                </thead>
                <tbody>
                  <% year3Active.forEach(module => { %>
                    <tr>
                      <td><%= module.name %></td>
                      <td><%= module.module_code %></td>
                      <td><%= module.ProgrammeModule.credits %></td>
                      <td>
                        <% if (module.ProgrammeModule.mandatory) { %>
                          <span class="badge bg-primary">Mandatory</span>
                        <% } else { %>
                          <span class="badge bg-secondary">Optional</span>
                        <% } %>
                      </td>
                      <td>
                        <a href="/academic/moduleResults/<%= programme.id %>/<%= module.id %>" class="btn btn-sm dashboardButton">View</a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>

          <% if (year3Inactive.length > 0) { %>
            <h6 class="mt-3 text-muted">Inactive</h6>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Credits</th>
                  </tr>
                </thead>
                <tbody>
                  <% year3Inactive.forEach(module => { %>
                    <tr class="text-muted">
                      <td><%= module.name %></td>
                      <td><%= module.module_code %></td>
                      <td><%= module.ProgrammeModule.credits %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

      </div>
      <% } %>

    </div>
  </div>
</div>

<div class="pageSpacing"></div>

</body>
</html>