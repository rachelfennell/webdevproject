<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Academic Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body><nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">
 <%# Top row %>
    <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
      <a class="navbar-brand mb-0" href="/academic/dashboard">
        <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
      </a>
      <span class="text-white">Logged in as <%= user.first_name %> <%= user.last_name %></span>
    </div>

  <%# Bottom row %>
  <div class="w-100 py-2 d-flex justify-content-end">
      <ul class="navbar-nav flex-row gap-3">
        <li class="nav-item">
        <a class="nav-link" href="/academic/dashboard">Home</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/studentList">Students List</a>
      </li>
<li class="nav-item dropdown">
  <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
    Assigned Programmes
  </a>
  <ul class="dropdown-menu">
  <% if (userProgrammes && userProgrammes.length > 0) { %>
    <% userProgrammes.forEach(userProgramme => { %>
      <li>
        <a class="dropdown-item" href="/academic/programmeDashboard/<%= userProgramme.Programme.id %>">
          <%= userProgramme.Programme.name  .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
           
        </a>
      </li>
    <% }) %>
  <% } else { %>
    <li><span class="dropdown-item text-muted">No programmes assigned</span></li>
  <% } %>
</ul>
</li>
      <li class="nav-item">
        <a class="nav-link" href="/academic/auditLog">Audit Log</a>
      </li>
       <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>

 <div class="container mt-5">

  <div class="row g-4">

    <!-- LEFT -->
    <div class="col-12 col-lg-4">

      <div class="card shadow-sm p-3">

        <div class="d-flex justify-content-between align-items-center">
          <h4 class="mb-0">
            <%= programme.name .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ') %>
          </h4>

          <a href="/academic/editProgramme/<%= programme.id %>"
             class="btn btn-sm dashboardButton">
            Edit
          </a>
        </div>

        <hr>

        <p><strong>Code:</strong> <%= programme.programme_code %></p>
        <p><strong>Degree:</strong> <%= programme.degree_type %></p>
        <p><strong>School:</strong> <%= programme.school %></p>

        <p>
          <strong>Status:</strong>
          <%= programme.active ? 'Active' : 'Inactive' %>
        </p>

        <p><strong>Pass Mark:</strong> <%= programme.pass_mark %>%</p>
        <p><strong>Resit Cap:</strong> <%= programme.resit_cap %>%</p>

        <p><strong>Y2 Weight:</strong> <%= (programme.y2_weight * 100).toFixed(0) %>%</p>
        <p><strong>Y3 Weight:</strong> <%= (programme.y3_weight * 100).toFixed(0) %>%</p>

      </div>

    </div>

    <!-- RIGHT-->
    <div class="col-12 col-lg-8">

      
      <div class="card shadow-sm mb-4">

        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Students</h5>

          <a href="/academic/programmeStudentList/<%= programme.id %>"
             class="btn btn-sm dashboardButton">
            View All
          </a>
        </div>

        <div class="card-body">

          <p class="mb-3">
            <strong>Active Students:</strong> <%= students.length %>
          </p>

          <a href="/academic/programmeClassification/<%= programme.id %>"
             class="btn btn-success btn-sm">
            Run Programme Classification
          </a>

        </div>
      </div>

    
      <div class="card shadow-sm mb-4">

        <div class="card-header bg-white">
          <h5 class="mb-0">Flagged Students</h5>
        </div>

<%
  const flagged = students.filter(student => {
    if (!student.Results || student.Results.length === 0) return true;

    const moduleIds = [...new Set(student.Results.map(r => r.module_id))];

    return moduleIds.some(moduleId => {
      const effectiveMark = getOverallMark(moduleId, student.Results, programme.resit_cap);
      return effectiveMark !== null && effectiveMark < programme.pass_mark;
    });
  });
%>

        <div class="card-body table-responsive">

          <% if (flagged.length === 0) { %>

            <div class="alert alert-success mb-0">
              No flagged students.
            </div>

          <% } else { %>

            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Student</th>
                  <th>Number</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>

              <tbody>
                <% flagged.forEach(student => { %>
                  <tr>
                    <td><%= student.first_name %> <%= student.last_name %></td>
                    <td><%= student.student_number %></td>
                    <td>
                      <% if (student.Results.length === 0) { %>
                        <span class="badge bg-warning text-dark">No Results</span>
                      <% } else { %>
                        <span class="badge bg-danger">Flagged</span>
                      <% } %>
                    </td>
                    <td>
                      <a href="/academic/studentProfile/<%= student.id %>"
                         class="btn btn-info btn-sm">
                        View
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>

          <% } %>

        </div>
      </div>

<div class="card shadow-sm mb-4">

  <div class="card-header bg-white">
    <h5 class="mb-0">Active Modules</h5>
  </div>

  <div class="card-body">

    <% const activeModules = programme.Modules.filter(m => m.ProgrammeModule.active); %>

    <% if (activeModules.length > 0) { %>

      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Code</th>
              <th>Year</th>
              <th>Credits</th>
              <th>Type</th>
              <th>Results</th>
            </tr>
          </thead>

          <tbody>
            <% activeModules.forEach(module => { %>
              <tr>
                <td><%= module.name %></td>
                <td><%= module.module_code %></td>
                <td><%= module.ProgrammeModule.year_level %></td>
                <td><%= module.ProgrammeModule.credits %></td>
                <td>
                  <% if (module.ProgrammeModule.mandatory) { %>
                    <span class="badge bg-primary">Mandatory</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Optional</span>
                  <% } %>
                </td>
                <td>
                  <a href="/academic/moduleResults/<%= programme.id %>/<%= module.id %>"
                     class="btn btn-sm dashboardButton">
                    View
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

    <% } else { %>
      <p class="text-muted mb-0">No active modules.</p>
    <% } %>

  </div>
</div>


<div class="card shadow-sm">

  <div class="card-header bg-white">
    <h5 class="mb-0">Inactive Modules</h5>
  </div>

  <div class="card-body">

    <% const inactiveModules = programme.Modules.filter(m => !m.ProgrammeModule.active); %>

    <% if (inactiveModules.length > 0) { %>

      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Code</th>
              <th>Year</th>
              <th>Credits</th>
            </tr>
          </thead>

          <tbody>
            <% inactiveModules.forEach(module => { %>
              <tr class="text-muted">
                <td><%= module.name %></td>
                <td><%= module.module_code %></td>
                <td><%= module.ProgrammeModule.year_level %></td>
                <td><%= module.ProgrammeModule.credits %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

    <% } else { %>
      <p class="text-muted mb-0">No inactive modules.</p>
    <% } %>

  </div>

</div>

    </div>

  </div>
</div>

<div class="pageSpacing"></div>

</body>
</html>