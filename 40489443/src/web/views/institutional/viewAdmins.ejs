<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>View All Academic Admins</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container">
      <a class="navbar-brand" href="#">HEdClass</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link">Logged in as <%= user.first_name %>
                <%= user.last_name %></span>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>


  <h1>All Academic Admins</h1>


  <div class="container">

    <table class="table table-striped">
      <thead>
        <tr>
          <th>Name</th>
          <th>Username</th>
          <th>Email</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% admins.forEach(admin=> { %>
          <tr>
            <td>
              <%= admin.first_name %>
                <%= admin.last_name %>
            </td>
            <td>
              <%= admin.username %>
            </td>
            <td>
              <%= admin.email %>
            </td>
            <td> <a href="/institutional/adminProfile/<%= admin.id %>">
              <button type="button"class="btn btn-info">Info</button></td>
          </tr>
          <% }) %>
      </tbody>
    </table>


  </div>


  </div>
</body>

</html>