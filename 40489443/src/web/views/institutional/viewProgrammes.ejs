<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Programmes | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body>

  <nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">

    <%# Top row %>
      <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
        <a class="navbar-brand mb-0" href="/institutional/dashboard">
          <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
        </a>
        <span class="text-white">Logged in as <%= user.first_name %>
            <%= user.last_name %></span>
      </div>

      <%# Bottom row %>
        <div class="w-100 py-2 d-flex justify-content-end">
          <ul class="navbar-nav flex-row gap-3">
            <li class="nav-item">
              <a class="nav-link" href="/institutional/dashboard">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/institutional/manageAdmins">Admin Management</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/institutional/manageProgrammes">Programme Management</a>
            </li>
            <li class="nav-item">
              <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </li>
          </ul>
        </div>

  </nav>


  <div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
    </div>

    <div class="row g-4">

      <%# Active Programmes %>
        <div class="col-12">
          <div class="card shadow-sm">
            <div class="card-header bg-white">
              <h5 class="mb-0">Active Programmes</h5>
            </div>
            <div class="card-body table-responsive">
              <% const activeProgrammes=programmes.filter(p=> p.active) %>
                <% if (activeProgrammes.length> 0) { %>
                  <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                      <tr>
                        <th>Programme Code</th>
                        <th>Name</th>
                        <th>Degree Type</th>
                        <th>School</th>
                        <th>Action</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% activeProgrammes.forEach(programme=> { %>
                        <tr>
                          <td>
                            <%= programme.programme_code %>
                          </td>
                          <td>
                            <%=
                              programme.name.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ') %></td>
                      <td><%= programme.degree_type %></td>
                      <td><%= programme.school %></td>
                      <td>
                        <a href="/institutional/programmeProfile/<%= programme.id %>" class="btn dashboardButton btn-sm">
                          View
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } else { %>
              <p class="text-muted mb-0">No active programmes found.</p>
            <% } %>
          </div>
        </div>
      </div>

      <%# Inactive Programmes %>
      <div class="col-12">
        <div class="card shadow-sm">
          <div class="card-header bg-white">
            <h5 class="mb-0">Inactive Programmes</h5>
          </div>
          <div class="card-body table-responsive">
            <% const inactiveProgrammes = programmes.filter(p => !p.active) %>
            <% if (inactiveProgrammes.length > 0) { %>
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Programme Code</th>
                    <th>Name</th>
                    <th>Degree Type</th>
                    <th>School</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% inactiveProgrammes.forEach(programme => { %>
                    <tr class="text-muted">
                      <td><%= programme.programme_code %></td>
                      <td><%= programme.name.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ') %></td>
                      <td><%= programme.degree_type %></td>
                      <td><%= programme.school %></td>
                      <td>
                        <a href="/institutional/programmeProfile/<%= programme.id %>" class="btn btn-outline-secondary btn-sm">
                          View
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } else { %>
              <p class="text-muted mb-0">No inactive programmes found.</p>
            <% } %>
          </div>
        </div>
      </div>

    </div>
  </div>
  <div class="pageSpacing"></div>

</body>
</html>