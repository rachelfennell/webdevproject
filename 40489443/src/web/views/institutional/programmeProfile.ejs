<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>View Programme Profile Page</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container">
      <a class="navbar-brand" href="#">HEdClass</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link">Logged in as <%= user.first_name %> <%= user.last_name %></span>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

<div>
  <div>
<h1><%= programme.name %> Profile </h1>
<p>Programme Code:  <%= programme.programme_code %></p>
<p>Degree Type:  <%= programme.degree_type %></p>
<p>School: <%= programme.school %></p>
</div>

<div class="col-md-3">
            <p class="text-muted mb-1">Status</p>
            <% if (programme.active) { %>
              <span class="badge bg-success">Active</span>
            <% } else { %>
              <span class="badge bg-secondary">Inactive</span>
            <% } %>
          </div>

        <div class="row mt-2">
          <div class="col-md-3">
            <p class="text-muted mb-1">Year 2 Weight</p>
            <p><%= (programme.y2_weight * 100).toFixed(0) %>%</p>
          </div>
          <div class="col-md-3">
            <p class="text-muted mb-1">Year 3 Weight</p>
            <p><%= (programme.y3_weight * 100).toFixed(0) %>%</p>
          </div>
          <div class="col-md-3">
            <p class="text-muted mb-1">Resit Cap</p>
            <p><%= programme.resit_cap %>%</p>
          </div>
        </div>




<div>
  <h2>Modules</h2>

  // Active Modules


  <% if (programme.Modules && programme.Modules.length > 0) { %>
    <h3>Currently Assigned Modules</h3>
    <table class="table">
      <thead>
        <tr>
          <th>Module Name</th>
          <th>Module Code</th>
       <th>Year Level</th>
                <th>Credits</th>
                <th>Mandatory</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% programme.Modules.forEach(module => { 
          if (module.ProgrammeModule.active) { %> 
            <tr>
         <td><%= module.name %></td>
                  <td><%= module.module_code %></td>
                  <td>Year <%= module.ProgrammeModule.year_level %></td>
                  <td><%= module.ProgrammeModule.credits %></td>



       <td> <% if (module.ProgrammeModule.mandatory) { %>
                      <span class="badge bg-primary">Mandatory</span>
                    <% } else { %>
                      <span class="badge bg-secondary">Optional</span>
                    <% } %>
                  </td>
                  <td>Active</td>
            </tr>
        <% } }) %>
      </tbody>
    </table>
  <% } else { %>
    <p>No active modules assigned to this programme.</p>
  <% } %>

 // Unassigned
  <% if (programme.Modules && programme.Modules.length > 0) { %>
    <h3>Inactive Modules</h3>
    <table class="table">
      <thead>
        <tr>
          <th>Module Name</th>
          <th>Module Code</th>
       <th>Year Level</th>
                <th>Credits</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% programme.Modules.forEach(module => { 
          if (module.ProgrammeModule.inactive) { %> 
            <tr>
              <td><%= module.name %></td>
              <td><%= module.module_code %></td>
              <td>Year <%= module.ProgrammeModule.year_level %></td>
                  <td><%= module.ProgrammeModule.credits %></td>
              <td>Inactive</td>
            </tr>
        <% } }) %>
      </tbody>
    </table>
  <% } else { %>
    <p>No inactive modules.</p>
  <% } %>
</div>



<div>
  <a href="/institutional/editProgramme/<%= programme.id %>" class="btn btn-primary">Edit Programme</a>
</div>


</div>
<a href="/institutional/viewProgrammes" class="btn btn-secondary">Back to Programme List</a>

</body>
</html>
