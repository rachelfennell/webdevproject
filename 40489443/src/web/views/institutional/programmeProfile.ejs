<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Institutional Programme Profile | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body>

  <nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">

    <%# Top row %>
      <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
        <a class="navbar-brand mb-0" href="/institutional/dashboard">
          <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
        </a>
        <span class="text-white">Logged in as <%= user.first_name %>
            <%= user.last_name %></span>
      </div>

      <%# Bottom row %>
        <div class="w-100 py-2 d-flex justify-content-end">
          <ul class="navbar-nav flex-row gap-3">
            <li class="nav-item">
              <a class="nav-link" href="/institutional/dashboard">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/institutional/manageAdmins">Admin Management</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/institutional/manageProgrammes">Programme Management</a>
            </li>
            <li class="nav-item">
              <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </li>
          </ul>
        </div>

  </nav>

  <div class="container mt-5">
    <div class="row g-4">


      <div class="col-12 col-lg-4">

        <div class="card shadow-sm p-3">

          <div class="d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Programme Profile</h4>

            <a href="/institutional/editProgramme/<%= programme.id %>" class="btn btn-sm dashboardButton">
              Edit
            </a>
          </div>

          <hr>

          <p>
            <strong>Name:</strong>
            <%= programme.name .split(' ')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ')
%>
        </p>

        <p>
          <strong>Programme Code:</strong>
          <%= programme.programme_code %>
        </p>

        <p>
          <strong>Degree Type:</strong>
          <%= programme.degree_type %>
        </p>

        <p>
          <strong>School:</strong>
          <%= programme.school %>
        </p>

        <p>
          <strong>Status:</strong>
          <%= programme.active ? 'Active' : 'Inactive' %>
          </p>

          <hr>

          <p>
            <strong>Year 2 Weight:</strong>
            <%= (programme.y2_weight * 100).toFixed(0) %>%
          </p>

          <p>
            <strong>Year 3 Weight:</strong>
            <%= (programme.y3_weight * 100).toFixed(0) %>%
          </p>

          <p>
            <strong>Resit Cap:</strong>
            <%= programme.resit_cap %>%
          </p>

        </div>
      </div>



      <div class="col-12 col-lg-8">

        <div class="card shadow-sm mb-4">

          <div class="card-header bg-white">
            <h5 class="mb-0">Currently Assigned Modules</h5>
          </div>

          <div class="card-body table-responsive">

            <% const y1Modules=programme.Modules.filter(m=> m.ProgrammeModule.active && m.ProgrammeModule.year_level ===
              '1') %>
              <% const y2Modules=programme.Modules.filter(m=> m.ProgrammeModule.active && m.ProgrammeModule.year_level
                === '2') %>
                <% const y3Modules=programme.Modules.filter(m=> m.ProgrammeModule.active && m.ProgrammeModule.year_level
                  === '3') %>

                  <% if (programme.Modules && programme.Modules.length> 0) { %>

                    <%# Year 1 %>
                      <h6 class="text-muted mt-2">Year 1</h6>
                      <% if (y1Modules.length> 0) { %>
                        <table class="table align-middle mb-4">
                          <thead class="table-light">
                            <tr>
                              <th>Module Name</th>
                              <th>Module Code</th>
                              <th>Credits</th>
                              <th>Mandatory</th>
                            </tr>
                          </thead>
                          <tbody>
                            <% y1Modules.forEach(module=> { %>
                              <tr>
                                <td>
                                  <%= module.name %>
                                </td>
                                <td>
                                  <%= module.module_code %>
                                </td>
                                <td>
                                  <%= module.ProgrammeModule.credits %>
                                </td>
                                <td>
                                  <% if (module.ProgrammeModule.mandatory) { %>
                                    <span class="badge bg-primary">Mandatory</span>
                                    <% } else { %>
                                      <span class="badge bg-secondary">Optional</span>
                                      <% } %>
                                </td>
                              </tr>
                              <% }) %>
                          </tbody>
                        </table>
                        <% } else { %>
                          <p class="text-muted small mb-4">No modules assigned for Year 1.</p>
                          <% } %>

                            <%# Year 2 %>
                              <h6 class="text-muted">Year 2</h6>
                              <% if (y2Modules.length> 0) { %>
                                <table class="table align-middle mb-4">
                                  <thead class="table-light">
                                    <tr>
                                      <th>Module Name</th>
                                      <th>Module Code</th>
                                      <th>Credits</th>
                                      <th>Mandatory</th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    <% y2Modules.forEach(module=> { %>
                                      <tr>
                                        <td>
                                          <%= module.name %>
                                        </td>
                                        <td>
                                          <%= module.module_code %>
                                        </td>
                                        <td>
                                          <%= module.ProgrammeModule.credits %>
                                        </td>
                                        <td>
                                          <% if (module.ProgrammeModule.mandatory) { %>
                                            <span class="badge bg-primary">Mandatory</span>
                                            <% } else { %>
                                              <span class="badge bg-secondary">Optional</span>
                                              <% } %>
                                        </td>
                                      </tr>
                                      <% }) %>
                                  </tbody>
                                </table>
                                <% } else { %>
                                  <p class="text-muted small mb-4">No modules assigned for Year 2.</p>
                                  <% } %>

                                    <%# Year 3 %>
                                      <h6 class="text-muted">Year 3</h6>
                                      <% if (y3Modules.length> 0) { %>
                                        <table class="table align-middle mb-4">
                                          <thead class="table-light">
                                            <tr>
                                              <th>Module Name</th>
                                              <th>Module Code</th>
                                              <th>Credits</th>
                                              <th>Mandatory</th>
                                            </tr>
                                          </thead>
                                          <tbody>
                                            <% y3Modules.forEach(module=> { %>
                                              <tr>
                                                <td>
                                                  <%= module.name %>
                                                </td>
                                                <td>
                                                  <%= module.module_code %>
                                                </td>
                                                <td>
                                                  <%= module.ProgrammeModule.credits %>
                                                </td>
                                                <td>
                                                  <% if (module.ProgrammeModule.mandatory) { %>
                                                    <span class="badge bg-primary">Mandatory</span>
                                                    <% } else { %>
                                                      <span class="badge bg-secondary">Optional</span>
                                                      <% } %>
                                                </td>
                                              </tr>
                                              <% }) %>
                                          </tbody>
                                        </table>
                                        <% } else { %>
                                          <p class="text-muted small mb-4">No modules assigned for Year 3.</p>
                                          <% } %>

                                            <% } else { %>
                                              <p class="text-muted">No active modules assigned.</p>
                                              <% } %>

          </div>

        </div>



        <div class="card shadow-sm">

          <div class="card-header bg-white">
            <h5 class="mb-0">Inactive Modules</h5>
          </div>

          <div class="card-body table-responsive">

            <% if (programme.Modules && programme.Modules.length> 0) { %>

              <table class="table align-middle">
                <thead>
                  <tr>
                    <th>Module Name</th>
                    <th>Module Code</th>
                    <th>Year Level</th>
                    <th>Credits</th>

                  </tr>
                </thead>

                <tbody>
                  <% programme.Modules.forEach(module=> { %>
                    <% if (!module.ProgrammeModule.active) { %>
                      <tr>
                        <td>
                          <%= module.name %>
                        </td>
                        <td>
                          <%= module.module_code %>
                        </td>
                        <td>Year <%= module.ProgrammeModule.year_level %>
                        </td>
                        <td>
                          <%= module.ProgrammeModule.credits %>
                        </td>

                      </tr>
                      <% } %>
                        <% }) %>
                </tbody>
              </table>

              <% } else { %>
                <p>No inactive modules.</p>
                <% } %>

          </div>
        </div>

      </div>
    </div>
  </div>


  <div class="container mt-5 mb-5">
    <div class="d-flex justify-content-end">
      <a href="/institutional/viewProgrammes" class="btn btn-sm dashboardButton">
        Back to Programme List
      </a>
    </div>
  </div>

  <div class="pageSpacing"></div>
</body>

</html>