<h3>Academic Administrators</h3>
<a href="/institutional/admins" class="btn btn-success mb-3">Add Academic Admin</a>

<table class="table table-bordered">
  <thead>
    <tr>
      <th>Username</th>
      <th>Name</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% admins.forEach(admin => { %>
      <tr>
        <td><%= admin.username %></td>
        <td><%= admin.first_name %> <%= admin.last_name %></td>
        <td>
          <a href="/institutional/admins/edit/<%= admin.id %>" class="btn btn-sm btn-primary">Edit</a>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>