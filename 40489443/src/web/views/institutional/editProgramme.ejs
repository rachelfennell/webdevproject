<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Academic Admins</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.10.2/dist/umd/popper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container">
      <a class="navbar-brand" href="#">HEdClass</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link">Logged in as <%= user.first_name %>
                <%= user.last_name %></span>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container">
    <h1>Edit Programme: <%= programme.name %>
    </h1>


    <form action="/institutional/editProgramme/<%= programme.id %>" method="POST">
      <div class="form-group">
        <label for="name">Name:</label>
        <input type="text" class="form-control" id="name" name="name" value="<%= programme.name %>" required />
      </div>

 <div class="form-group">
        <label for="programme_code">Programme Code:</label>
        <input type="text" class="form-control" id="programme_code" name="programme_code" value="<%= programme.programme_code %>" required />
      </div>

      <div class="form-group">
        <label for="degree_type">Degree Type:</label>
        <input type="text" class="form-control" id="degree_type" name="degree_type" value="<%= programme.degree_type %>"
          required />
      </div>

      <div class="form-group">
        <label for="school">school:</label>
        <input type="text" class="form-control" id="school" name="school" value="<%= programme.school %>"
          required />
      </div>

       <div class="form-group">
        <label for="y2_weight">y2_weight:</label>
        <input type="text" class="form-control" id="y2_weight" name="y2_weight" value="<%= programme.y2_weight %>"
          required />
      </div>

       <div class="form-group">
        <label for="y3_weight">y3_weight:</label>
        <input type="text" class="form-control" id="y3_weight" name="y3_weight" value="<%= programme.y3_weight %>"
          required />
      </div>

       <div class="form-group">
        <label for="resit_cap">resit_cap:</label>
        <input type="text" class="form-control" id="resit_cap" name="resit_cap" value="<%= programme.resit_cap %>"
          required />
      </div>

      <div class="form-group mb-3">
  <label for="pass_mark">Pass Mark</label>
  <input 
    type="number" 
    class="form-control" 
    id="pass_mark" 
    name="pass_mark" 
    value="40"
    min="0" 
    max="100" 
    required />
</div>

      <div class="form-group">
        <label for="active">Active:</label>
        <input type="checkbox" id="active" name="active" value="on" <%=programme.active ? 'checked' : '' %> />
      </div>

<div>
<form action="/institutional/editProgramme/<%= programme.id %>" method="POST">

  <button type="submit" class="btn btn-primary">Save Changes</button>
</form>

<!--- assigned modules table-->
    <div class="card shadow-sm">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Assigned Modules</h5>

        <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#assignModule"> + Assign Module </button>
      </div>




      <div class="card-body">
       <% if (programme.Modules && programme.Modules.length > 0) { %>
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
               <th>Module Name</th>
          <th>Module Code</th>
       <th>Year Level</th>
                <th>Credits</th>
                <th>Mandatory</th>
          <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% programme.Modules.forEach(module => {  %>
                <tr>
                  <td><%= module.name %></td>
                  <td><%= module.module_code %></td>
                  <td>Year <%= module.ProgrammeModule.year_level %></td>
                  <td><%= module.ProgrammeModule.credits %></td>
                      <td> <% if (module.ProgrammeModule.mandatory) { %>
                      <span class="badge bg-primary">Mandatory</span>
                    <% } else { %>
                      <span class="badge bg-secondary">Optional</span>
                    <% } %>

                    <% if (module.ProgrammeModule.active) { %>
                      <span class="badge bg-success">Active</span>
                    <% } else { %>
                      <span class="badge bg-secondary">Inactive</span>
                    <% } %>
                  </td>
                  <td>
                    <form action="/institutional/removeModule/<%= programme.id %>" method="POST">
                      <input type="hidden" name="moduleId" value="<%= module.id %>" />
                      <button
                        type="submit"
                        class="btn btn-danger btn-sm"
                        onclick="return confirm('Are you sure you want to unassign this module?')">
                        Unassign
                      </button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <div class="alert alert-info mb-0">
            No modules currently assigned to this programme.
          </div>
        <% } %>
      </div>
    </div>

  </div>

<!--- Modal for assigning modules-->
<div class="modal fade" id="assignModule" tabindex="-1" aria-labelledby="assignModuleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="assignModuleModalLabel">Select and Assign a Module</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form action="/institutional/assignModule/<%= programme.id %>" method="POST">
            <div class="form-group">
              <label for="moduleId">Select Module:</label>
              <select id="moduleId" name="moduleId" class="form-control" required>
                <option value="">Select a Module</option>
                <% activeModules.forEach(module => { %>
                  <option value="<%= module.id %>"><%= module.name %> - <%= module.module_code %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group mt-3">
              <label for="year_level">Year Level:</label>
              <input type="number" class="form-control" id="year_level" name="year_level" required />
            </div>
            <div class="form-group mt-3">
              <label for="credits">Credits:</label>
              <input type="number" class="form-control" id="credits" name="credits" required />
            </div>
            <div class="form-group mt-3">
              <label for="mandatory">Mandatory:</label>
              <select class="form-control" id="mandatory" name="mandatory" required>
                <option value="true">Yes</option>
                <option value="false">No</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary mt-3">Assign Module</button>
          </form>
        </div>
      </div>
    </div>
  </div>

























      <button type="submit" class="btn btn-primary mt-3">Update Programme</button>
    </form>

     



     

</body>

</html>