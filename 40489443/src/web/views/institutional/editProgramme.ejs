<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Institutional Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.10.2/dist/umd/popper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body>

  <nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">

    <%# Top row %>
    <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
      <a class="navbar-brand mb-0" href="/institutional/dashboard">
        <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
      </a>
      <span class="text-white">Logged in as <%= user.first_name %> <%= user.last_name %></span>
    </div>

    <%# Bottom row %>
    <div class="w-100 py-2 d-flex justify-content-end">
      <ul class="navbar-nav flex-row gap-3">
        <li class="nav-item">
          <a class="nav-link" href="/institutional/dashboard">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/institutional/manageAdmins">Admin Management</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/institutional/manageProgrammes">Programme Management</a>
        </li>
        <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>

<div class="container mt-5">
  <div class="row g-4">

    <!-- LEFT COLUMN: PROGRAMME DETAILS FORM -->
    <div class="col-12 col-lg-4">

      <div class="card shadow-sm p-3">

        <div class="d-flex justify-content-between align-items-center">
          <h4 class="mb-0">Edit Programme</h4>
        </div>

        <hr>

        <form action="/institutional/editProgramme/<%= programme.id %>" method="POST">

  <div class="form-group mb-3">
        <label for="name">Name:</label>
        <input type="text" class="form-control" id="name" name="name"
          value="<%= programme.name %>" required />
      </div>

      <div class="form-group mb-3">
        <label for="programme_code">Programme Code:</label>
        <input type="text" class="form-control" id="programme_code" name="programme_code"
          value="<%= programme.programme_code %>" required />
      </div>

      <div class="form-group mb-3">
        <label for="degree_type">Degree Type:</label>
        <select class="form-control" id="degree_type" name="degree_type" required>
          <option value="BSc" <%= programme.degree_type === 'BSc' ? 'selected' : '' %>>BSc</option>
          <option value="BA" <%= programme.degree_type === 'BA' ? 'selected' : '' %>>BA</option>
          <option value="LLB" <%= programme.degree_type === 'LLB' ? 'selected' : '' %>>LLB</option>
          <option value="BEng" <%= programme.degree_type === 'BEng' ? 'selected' : '' %>>BEng</option>
        </select>
      </div>

      <div class="form-group mb-3">
        <label for="school">School:</label>
        <select class="form-control" id="school" name="school" required>
          <option value="EEECS" <%= programme.school === 'EEECS' ? 'selected' : '' %>>EEECS</option>
          <option value="Law" <%= programme.school === 'Law' ? 'selected' : '' %>>Law</option>
          <option value="Arts" <%= programme.school === 'Arts' ? 'selected' : '' %>>Arts</option>
        </select>
      </div>

      <div class="form-group mb-3">
        <label for="y2_weight">Year 2 Weight:</label>
        <input type="number" step="0.01" class="form-control" id="y2_weight" name="y2_weight"
          value="<%= programme.y2_weight %>" required />
      </div>

      <div class="form-group mb-3">
        <label for="y3_weight">Year 3 Weight:</label>
        <input type="number" step="0.01" class="form-control" id="y3_weight" name="y3_weight"
          value="<%= programme.y3_weight %>" required />
      </div>

      <div class="form-group mb-3">
        <label for="resit_cap">Resit Cap:</label>
        <input type="number" class="form-control" id="resit_cap" name="resit_cap"
          value="<%= programme.resit_cap %>" required />
      </div>

<div class="form-group mb-3">
  <label for="pass_mark">Pass Mark</label>
  <input 
    type="number" 
    class="form-control" 
    id="pass_mark" 
    name="pass_mark" 
    value="40"
    min="0" 
    max="100" 
    required />
</div>

      <div class="form-group mb-3">
        <label for="active">Active:</label>
        <input type="checkbox" id="active" name="active" value="on"
          <%= programme.active ? 'checked' : '' %> />
      </div>


          <button type="submit" class="btn dashboardButton">
            Update Programme
          </button>

        </form>

      </div>
    </div>


   
    <div class="col-12 col-lg-8">

     
      <div class="card shadow-sm mb-4">

        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Assigned Modules</h5>

          <button type="button"
                  class="btn btn-success btn-sm"
                  data-bs-toggle="modal"
                  data-bs-target="#assignModule">
            + Assign Module
          </button>
        </div>

        <div class="card-body table-responsive">

          <% if (programme.Modules && programme.Modules.length > 0) { %>

            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Name</th>
                  <th>Code</th>
                  <th>Year</th>
                  <th>Credits</th>
                  <th>Mandatory</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>

              <tbody>
                <% programme.Modules.forEach(module => { %>
                  <tr>
                    <td><%= module.name %></td>
                    <td><%= module.module_code %></td>
                    <td>Year <%= module.ProgrammeModule.year_level %></td>
                    <td><%= module.ProgrammeModule.credits %></td>

                    <td>
                      <% if (module.ProgrammeModule.mandatory) { %>
                        <span class="badge bg-primary">Mandatory</span>
                      <% } else { %>
                        <span class="badge bg-secondary">Optional</span>
                      <% } %>
                    </td>

                    <td>
                      <% if (module.ProgrammeModule.active) { %>
                        <span class="badge bg-success">Active</span>
                      <% } else { %>
                        <span class="badge bg-secondary">Inactive</span>
                      <% } %>
                    </td>

                    <td>
                      <form action="/institutional/removeModule/<%= programme.id %>" method="POST">
                        <input type="hidden" name="moduleId" value="<%= module.id %>">
                        <button class="btn btn-danger btn-sm"
                                onclick="return confirm('Unassign this module?')">
                          Unassign
                        </button>
                      </form>
                    </td>

                  </tr>
                <% }) %>
              </tbody>

            </table>

          <% } else { %>
            <div class="alert alert-info mb-0">
              No modules assigned to this programme.
            </div>
          <% } %>

        </div>
      </div>

    </div>
  </div>
</div>



<div class="modal fade" id="assignModule" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Assign Module</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">

        <form action="/institutional/assignModule/<%= programme.id %>" method="POST">

          <div class="mb-3">
            <label class="form-label">Select Module</label>

            <select name="moduleId" class="form-control" required>
              <option value="">Select</option>

              <% activeModules.forEach(module => { %>
                <option value="<%= module.id %>">
                  <%= module.name %> - <%= module.module_code %>
                </option>
              <% }) %>

            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Year Level</label>
            <input type="number" class="form-control" name="year_level" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Credits</label>
            <input type="number" class="form-control" name="credits" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Mandatory</label>

            <select class="form-control" name="mandatory" required>
              <option value="true">Yes</option>
              <option value="false">No</option>
            </select>
          </div>

          <button type="submit" class="btn btn-primary w-100">
            Assign Module
          </button>


        </form>

      </div>
    </div>
  </div>
</div>


<div class="container mt-5 mb-5">
  <div class="d-flex justify-content-end">
    <a href="/institutional/programmeProfile/<%= programme.id %>"
       class="btn btn-sm dashboardButton">
      Back to Programme Profile
    </a>
  </div>
</div>

<div class="pageSpacing"></div>


</body>
</html>