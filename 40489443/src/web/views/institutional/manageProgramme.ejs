<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Programme Management Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container">
      <a class="navbar-brand" href="#">HEdClass</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link">Logged in as <%= user.first_name %> <%= user.last_name %></span>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container">
    <h2>Programme Management Dashboard</h2>

    <div class="row g-4">
      <div class="col-md-6">
        <div class="card shadow-sm p-3">
          <h5>View All Programmes</h5>
          <p>Create, view, and assign administrators</p>
          <a href="/institutional/viewProgrammes" class="btn btn-primary">Go</a>
        </div>
      </div>

    <div class="row g-4">
      <div class="col-md-6">
        <div class="card shadow-sm p-3">
          <h5>Create New Programme</h5>
          <p>Create, view, and assign administrators</p>
          <a href="/institutional/createProgramme" class="btn btn-primary">Go</a>
        </div>
      </div>


    
    </div>
  </div>
</body>
</html>