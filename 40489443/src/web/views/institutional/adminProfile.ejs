<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>View All Academic Admins</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container">
      <a class="navbar-brand" href="#">HEdClass</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <span class="nav-link">Logged in as <%= user.first_name %> <%= user.last_name %></span>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

<div>
  <div>
<h1>Admin Profile: <%= admin.first_name %> <%= admin.last_name %></h1>
<p>Username: <%= admin.username %></p>
<p>Email: <%= admin.email %></p>
<p>Username: <%= admin.username %></p>
</div>

<div>
<h2>Assigned Programmes</h2>
<% if (admin.Programmes && admin.Programmes.length > 0) { %>
  <table class="table">
    <thead>
      <tr>
        <th>Programme Name</th>
        <th>Assigned Date</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% admin.Programmes.forEach(programme => { %>
        <tr>
          <td><%= programme.name %></td>
          <td><%= programme.UserProgramme.assigned_date %></td>
          <td><%= programme.UserProgramme.active ? 'Active' : 'Inactive' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } else { %>
  <p>No programmes assigned to this admin.</p>
<% } %>
</div>


<div>
  <a href="/institutional/admins/edit/<%= admin.id %>" class="btn btn-primary">Edit Admin</a>
</div>











</div>
<a href="/institutional/viewAdmins" class="btn btn-secondary">Back to Admin List</a>

</body>
</html>
