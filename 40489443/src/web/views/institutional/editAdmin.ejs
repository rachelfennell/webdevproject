<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Institutional Admin Dashboard | HEdClass</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.10.2/dist/umd/popper.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">

  <!-- Top row -->
  <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
    <a class="navbar-brand mb-0" href="/institutional/dashboard">
      <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
    </a>

    <span class="text-white">
      Logged in as <%= user.first_name %> <%= user.last_name %>
    </span>
  </div>

  <!-- Bottom row -->
  <div class="w-100 py-2 d-flex justify-content-end">
    <ul class="navbar-nav flex-row gap-3">
      <li class="nav-item">
        <a class="nav-link" href="/institutional/dashboard">Home</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/institutional/manageAdmins">Admin Management</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/institutional/manageProgrammes">Programme Management</a>
      </li>
      <li class="nav-item">
        <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
      </li>
    </ul>
  </div>

</nav>


<!-- MAIN LAYOUT -->
<div class="container mt-5">
  <div class="row g-4">

    <!-- LEFT COLUMN: EDIT ADMIN -->
    <div class="col-12 col-lg-4">

      <div class="card shadow-sm p-3">

        <div class="d-flex justify-content-between align-items-center">
          <h4 class="mb-0">Edit Admin</h4>
        </div>

        <hr>

        <form action="/institutional/editAdmin/<%= admin.id %>" method="POST">

          <div class="mb-3">
            <label class="form-label">Username</label>
            <input type="text" class="form-control" name="username"
                   value="<%= admin.username %>" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="text" class="form-control" name="email"
                   value="<%= admin.email %>" required>
          </div>

          <div class="mb-3">
            <label class="form-label">First Name</label>
            <input type="text" class="form-control" name="first_name"
                   value="<%= admin.first_name %>" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Last Name</label>
            <input type="text" class="form-control" name="last_name"
                   value="<%= admin.last_name %>" required>
          </div>

          <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox"
                   name="active" id="active"
                   <%= admin.active ? 'checked' : '' %>>
            <label class="form-check-label">Active</label>
          </div>

          <button type="submit" class="btn dashboardButton w-100">
            Save Changes
          </button>

        </form>

      </div>
    </div>


    <!-- RIGHT COLUMN: PROGRAMMES -->
    <div class="col-12 col-lg-8">

      <!-- ASSIGNED -->
      <div class="card shadow-sm mb-4">

        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="mb-0">Assigned Programmes</h5>

          <button type="button"
                  class="btn btn-success btn-sm"
                  data-bs-toggle="modal"
                  data-bs-target="#assignProgramme">
            + Assign Programme
          </button>
        </div>

        <div class="card-body table-responsive">

          <% if (admin.Programmes && admin.Programmes.length > 0) { %>

            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Name</th>
                  <th>Code</th>
                  <th>Degree</th>
                  <th>Assigned</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>

              <tbody>
                <% admin.Programmes.forEach(programme => { %>

                  <tr>
                    <td><%= programme.name %></td>
                    <td><%= programme.programme_code %></td>
                    <td><%= programme.degree_type %></td>

                    <td>
                      <%= new Date(programme.UserProgramme.assigned_date)
                          .toLocaleDateString('en-GB') %>
                    </td>

                    <td>
                      <% if (programme.UserProgramme.active) { %>
                        <span class="badge bg-success">Active</span>
                      <% } else { %>
                        <span class="badge bg-secondary">Inactive</span>
                      <% } %>
                    </td>

                    <td>
                      <form action="/institutional/removeProgramme/<%= admin.id %>" method="POST">
                        <input type="hidden" name="programmeId" value="<%= programme.id %>">
                        <button class="btn btn-danger btn-sm"
                                onclick="return confirm('Unassign this programme?')">
                          Unassign
                        </button>
                      </form>
                    </td>

                  </tr>

                <% }) %>
              </tbody>
            </table>

          <% } else { %>
            <div class="alert alert-info mb-0">
              No programmes assigned to this admin.
            </div>
          <% } %>

        </div>
      </div>


    </div>

  </div>
</div>



<div class="modal fade" id="assignProgramme" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Assign Programme</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">

        <form action="/institutional/assignProgramme/<%= admin.id %>" method="POST">

          <div class="mb-3">
            <label class="form-label">Select Programme</label>

            <select name="programmeId" class="form-control" required>
              <option value="">Select</option>

              <% activeProgrammes.forEach(programme => { %>
                <option value="<%= programme.id %>">
                  <%= programme.name %> - <%= programme.programme_code %>
                </option>
              <% }) %>

            </select>
          </div>

          <button type="submit" class="btn btn-primary w-100">
            Assign
          </button>

        </form>

      </div>
    </div>
  </div>
</div>

</body>
</html>