<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Institutional Admin Dashboard | HEdClass</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles/ui.css">
</head>

<body>

  <nav class="navbar navbar-expand-lg navbar-dark px-4 py-0">

    <%# Top row %>
    <div class="w-100 d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
      <a class="navbar-brand mb-0" href="/institutional/dashboard">
        <img src="/media/Logo_white.png" alt="QueensLogo" height="40">
      </a>
      <span class="text-white">Logged in as <%= user.first_name %> <%= user.last_name %></span>
    </div>

    <%# Bottom row %>
    <div class="w-100 py-2 d-flex justify-content-end">
      <ul class="navbar-nav flex-row gap-3">
        <li class="nav-item">
          <a class="nav-link" href="/institutional/dashboard">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/institutional/manageAdmins">Admin Management</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/institutional/manageProgrammes">Programme Management</a>
        </li>
        <li class="nav-item">
          <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
        </li>
      </ul>
    </div>

  </nav>

  <div class="container mt-4">
    <h2 class="text-center mb-4">Institutional Administrator Dashboard</h2>

    <div class="row g-4">
      <div class="col-md-6">
        <div class="card shadow-sm p-3">
          <h5>Manage Academic Administrators</h5>
          <p>Create, view, and assign administrators</p>
          <a href="/institutional/manageAdmins" class="btn dashboardButton">Go</a>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card shadow-sm p-3">
          <h5>Manage Programmes</h5>
          <p>Create programmes and assign modules</p>
          <a href="/institutional/manageProgrammes" class="btn dashboardButton">Go</a>
        </div>
      </div>
    </div>
  </div>

<div class="pageSpacing"></div>

 
</body>
</html>